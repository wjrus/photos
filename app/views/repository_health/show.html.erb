<% content_for :title, "Repository Health" %>

<section class="min-h-screen bg-stone-50 text-zinc-950">
  <%= render "shared/site_header" %>

  <main class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-4 border-b border-zinc-200 pb-5 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-700">Owner</p>
        <h1 class="mt-2 text-3xl font-semibold text-zinc-950">Repository health</h1>
        <p class="mt-2 text-sm text-zinc-600">Original file patrol checks local storage against recorded size and checksums.</p>
      </div>

      <div class="flex flex-wrap gap-2">
        <%= link_to "Refresh",
              repository_health_path,
              class: "inline-flex items-center justify-center rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-800 shadow-sm transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
        <%= button_to "Queue patrol",
              repository_health_path,
              method: :post,
              class: "inline-flex items-center justify-center rounded-lg bg-zinc-950 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-teal-700" %>
      </div>
    </div>

    <div class="mt-6 grid grid-cols-2 gap-3 lg:grid-cols-5">
      <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">Photos</p>
        <p class="mt-2 text-2xl font-semibold text-zinc-950"><%= number_with_delimiter(@totals.fetch(:photos)) %></p>
      </div>
      <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">Checked</p>
        <p class="mt-2 text-2xl font-semibold text-zinc-950"><%= number_with_delimiter(@totals.fetch(:checked)) %></p>
      </div>
      <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">Unchecked</p>
        <p class="mt-2 text-2xl font-semibold text-zinc-950"><%= number_with_delimiter(@totals.fetch(:never_checked)) %></p>
      </div>
      <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">Attention</p>
        <p class="mt-2 text-2xl font-semibold <%= @totals.fetch(:attention).positive? ? "text-rose-800" : "text-zinc-950" %>"><%= number_with_delimiter(@totals.fetch(:attention)) %></p>
      </div>
      <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">Drive archived</p>
        <p class="mt-2 text-2xl font-semibold text-zinc-950"><%= number_with_delimiter(@totals.fetch(:drive_archived)) %></p>
      </div>
    </div>

    <div class="mt-8 grid gap-6 xl:grid-cols-[1fr_28rem]">
      <section>
        <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-zinc-500">Recent checks</h2>
        <%= render "repository_health/check_table", checks: @recent_checks, empty: "No file health checks have run yet." %>
      </section>

      <aside class="space-y-6">
        <section>
          <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-zinc-500">Status</h2>
          <div class="mt-3 rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <% if @status_counts.any? %>
              <dl class="space-y-3 text-sm">
                <% FileHealthCheck::STATUSES.each do |status| %>
                  <% count = @status_counts.fetch(status, 0) %>
                  <div class="flex items-center justify-between gap-3">
                    <dt class="font-medium text-zinc-700"><%= status.humanize %></dt>
                    <dd class="<%= FileHealthCheck::ATTENTION_STATUSES.include?(status) && count.positive? ? "text-rose-800" : "text-zinc-950" %> font-semibold"><%= number_with_delimiter(count) %></dd>
                  </div>
                <% end %>
              </dl>
            <% else %>
              <p class="text-sm text-zinc-600">No check history.</p>
            <% end %>
          </div>
        </section>

        <section>
          <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-zinc-500">Needs attention</h2>
          <div class="mt-3 rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <% if @recent_attention.any? %>
              <ul class="space-y-4">
                <% @recent_attention.each do |check| %>
                  <li class="text-sm">
                    <div class="flex items-start justify-between gap-3">
                      <%= link_to check.photo.original_filename,
                            photo_path(check.photo),
                            class: "min-w-0 truncate font-medium text-zinc-950 underline decoration-zinc-300 underline-offset-4 hover:decoration-zinc-950",
                            title: check.photo.original_filename %>
                      <span class="shrink-0 rounded-lg border border-rose-200 bg-rose-50 px-2 py-1 text-xs font-semibold text-rose-900"><%= check.status %></span>
                    </div>
                    <% if check.error.present? %>
                      <p class="mt-2 break-words text-xs leading-5 text-rose-800"><%= check.error %></p>
                    <% end %>
                    <p class="mt-2 text-xs text-zinc-500"><%= time_ago_in_words(check.checked_at) %> ago</p>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-sm text-zinc-600">Nothing needs attention.</p>
            <% end %>
          </div>
        </section>
      </aside>
    </div>
  </main>
</section>
