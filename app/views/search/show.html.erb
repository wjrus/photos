<% content_for :title, "Search" %>

<% if current_user&.owner? %>
  <% content_for :header_actions do %>
    <%= render "photos/bulk_toolbar", albums: @albums, return_to: @search_return_path || search_path(@search_params), form_id: "search-photo-bulk-form" %>
  <% end %>
<% end %>

<section class="min-h-screen bg-stone-50 text-zinc-950"
         <%= %(data-controller="bulk-selection" data-bulk-selection-form-id-value="search-photo-bulk-form" data-bulk-selection-empty-label-value="Select photos, then choose an action.").html_safe if current_user&.owner? %>>
  <%= render "shared/site_header" %>

  <main class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-3 border-b border-zinc-200 pb-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <div class="flex flex-wrap items-center gap-3">
          <h1 class="text-2xl font-semibold text-zinc-950 sm:text-3xl">Search</h1>
          <% if @semantic_search_available %>
            <span class="inline-flex rounded-lg border border-teal-200 bg-teal-50 px-2 py-1 text-xs font-semibold text-teal-900">OpenCLIP visual search enabled</span>
          <% end %>
        </div>
      </div>
      <p class="max-w-xl text-sm text-zinc-600 sm:text-right">Find photos by name, place, person, camera, lens, or visual content.</p>
    </div>

    <% advanced_filters_visible = privileged_metadata_viewer? %>
    <% filter_params = @search_params.slice(:person_id, :place_id, :camera_model, :lens_model) %>
    <% filters_active = filter_params.values.any?(&:present?) %>

    <%= form_with url: search_path,
          method: :get,
          class: "mt-5 rounded-lg border border-zinc-200 bg-white p-2 shadow-sm",
          data: { controller: "stream-state-reset search-form", action: "submit->stream-state-reset#clear", turbo: false } do %>
      <div class="flex flex-col gap-2 sm:flex-row">
        <div class="flex min-w-0 flex-1 items-center rounded-lg border border-zinc-300 bg-white">
          <label for="q" class="sr-only">Search text</label>
          <input id="q" name="q" value="<%= @search_params[:q] %>" placeholder="<%= @semantic_search_available ? "Try car, flower, beach, kitchen..." : (advanced_filters_visible ? "Names, places, filenames..." : "Search public photo titles...") %>"
                 class="min-w-0 flex-1 border-0 bg-transparent px-3 py-2 text-sm focus:outline-auto"
                 data-search-form-target="query">
          <button type="button"
                  class="mr-1 rounded-md px-2 py-1 text-lg leading-none text-zinc-500 transition hover:bg-zinc-100 hover:text-zinc-950"
                  aria-label="Clear search text"
                  data-action="search-form#clearQuery">&times;</button>
        </div>

        <div class="flex shrink-0 gap-2">
          <% if advanced_filters_visible %>
            <details class="group relative" <%= "open" if filters_active %>>
              <summary class="flex cursor-pointer list-none items-center justify-center rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white">
                Filters<%= " (#{filter_params.values.count(&:present?)})" if filters_active %>
              </summary>
              <div class="absolute right-0 z-20 mt-2 w-[min(88vw,52rem)] rounded-lg border border-zinc-200 bg-white p-4 shadow-2xl">
                <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-4">
                  <div>
                    <label for="person_id" class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">Person</label>
                    <select id="person_id" name="person_id" class="mt-2 w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15">
                      <option value="">Any person</option>
                      <% @filter_options[:people].each do |person| %>
                        <option value="<%= person.id %>" <%= "selected" if @search_params[:person_id].to_s == person.id.to_s %>><%= person.name %></option>
                      <% end %>
                    </select>
                  </div>

                  <div>
                    <label for="place_id" class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">Place</label>
                    <select id="place_id" name="place_id" class="mt-2 w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15">
                      <option value="">Any place</option>
                      <% @filter_options[:places].each do |place| %>
                        <% place_id = PhotoLocation.place_id_for_name(place.name) %>
                        <option value="<%= place_id %>" <%= "selected" if @search_params[:place_id].to_s == place_id %>><%= place.name %></option>
                      <% end %>
                    </select>
                  </div>

                  <div>
                    <label for="camera_model" class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">Camera</label>
                    <select id="camera_model" name="camera_model" class="mt-2 w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15">
                      <option value="">Any camera</option>
                      <% @filter_options[:camera_models].each do |camera_model| %>
                        <option value="<%= camera_model %>" <%= "selected" if @search_params[:camera_model] == camera_model %>><%= camera_model %></option>
                      <% end %>
                    </select>
                  </div>

                  <div>
                    <label for="lens_model" class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">Lens</label>
                    <select id="lens_model" name="lens_model" class="mt-2 w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15">
                      <option value="">Any lens</option>
                      <% @filter_options[:lenses].each do |lens| %>
                        <option value="<%= lens %>" <%= "selected" if @search_params[:lens_model] == lens %>><%= lens %></option>
                      <% end %>
                    </select>
                  </div>
                </div>

                <div class="mt-4 flex justify-end">
                  <%= link_to "Clear filters", search_path(q: @search_params[:q].presence), class: "text-sm font-semibold text-zinc-600 underline decoration-zinc-300 underline-offset-4 hover:text-zinc-950 hover:decoration-zinc-950" %>
                </div>
              </div>
            </details>
          <% end %>

          <button type="submit" class="rounded-lg bg-zinc-950 px-4 py-2 text-sm font-semibold text-white transition hover:bg-teal-800">Search</button>
        </div>
      </div>
    <% end %>

    <div class="mt-6">
      <% if @photos.any? %>
        <%= render "photos/grid",
              photos: @photos,
              return_to: @search_return_path,
              feature_first: false,
              bulk_form_id: "search-photo-bulk-form",
              stream_target_photo_id: @stream_target_photo_id,
              next_cursor: @next_cursor,
              newer_cursor: @newer_cursor,
              next_page_path: @search_return_path %>
      <% elsif @search_active %>
        <div class="flex min-h-[340px] items-center justify-center rounded-lg border border-dashed border-zinc-300 bg-white p-8 text-center shadow-sm">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-700">No matches</p>
            <h2 class="mt-3 text-2xl font-semibold text-zinc-950">No photos matched that search.</h2>
          </div>
        </div>
      <% end %>
    </div>
  </main>
</section>
