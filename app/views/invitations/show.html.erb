<% content_for :title, "Accept invitation" %>

<section class="min-h-screen bg-stone-50 text-zinc-950">
  <%= render "shared/site_header" %>

  <main class="mx-auto flex min-h-[calc(100vh-5rem)] max-w-lg items-center px-4 py-10 sm:px-6">
    <div class="w-full rounded-lg border border-zinc-200 bg-white p-6 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-700">Invitation</p>
      <h1 class="mt-2 text-2xl font-semibold text-zinc-950"><%= @user.display_name %></h1>
      <p class="mt-2 text-sm text-zinc-600"><%= @user.email %></p>

      <%= button_to "Use Google",
            "/auth/google_oauth2",
            method: :post,
            data: { turbo: false },
            class: "mt-6 w-full rounded-lg border border-zinc-300 px-4 py-3 text-sm font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>

      <div class="my-6 border-t border-zinc-200"></div>

      <%= form_with model: @user, url: accept_invitation_path(params[:token]), method: :patch, class: "space-y-4" do |form| %>
        <div>
          <%= form.label :avatar, "Avatar", class: "text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500" %>
          <%= form.file_field :avatar, accept: "image/png,image/jpeg,image/webp,image/gif", class: "mt-2 block w-full text-sm text-zinc-700 file:mr-3 file:rounded-lg file:border file:border-zinc-300 file:bg-white file:px-3 file:py-2 file:text-sm file:font-semibold file:text-zinc-800 hover:file:border-zinc-950 hover:file:bg-zinc-950 hover:file:text-white" %>
        </div>
        <div>
          <%= form.label :password, "Password", class: "text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500" %>
          <%= form.password_field :password, autocomplete: "new-password", required: true, class: "mt-2 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15" %>
        </div>
        <div>
          <%= form.label :password_confirmation, "Confirm password", class: "text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500" %>
          <%= form.password_field :password_confirmation, autocomplete: "new-password", required: true, class: "mt-2 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15" %>
        </div>
        <label class="flex items-center gap-2 text-sm text-zinc-700">
          <%= check_box_tag :remember_me, "1", true, class: "size-4 rounded border-zinc-300 text-teal-700" %>
          Remember me on this browser
        </label>
        <%= form.submit "Set password", class: "w-full rounded-lg bg-zinc-950 px-4 py-3 text-sm font-semibold text-white transition hover:bg-teal-800" %>
      <% end %>
    </div>
  </main>
</section>
