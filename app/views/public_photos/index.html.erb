<% content_for :title, "Public photos" %>
<% content_for :body_class, "stream-timeline-scrollbar" if @timeline_periods.present? %>

<% content_for :header_actions do %>
  <%= render "photos/bulk_toolbar", albums: @albums, return_to: public_photos_path, form_id: "public-photo-bulk-form" %>
<% end %>

<section class="min-h-screen bg-stone-50 text-zinc-950"
         data-controller="bulk-selection"
         data-bulk-selection-form-id-value="public-photo-bulk-form"
         data-bulk-selection-empty-label-value="Select public photos, then choose an action.">
  <%= render "shared/site_header" %>

  <main class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="mb-6 border-b border-zinc-200 pb-5">
      <h1 class="text-3xl font-semibold text-zinc-950">Public photos</h1>
      <p class="mt-1 text-sm text-zinc-600"><%= pluralize(@photos.size, "public item") %></p>
    </div>

    <% if @photos.any? %>
      <%= render "photos/grid",
            photos: @photos,
            return_to: public_photos_path,
            feature_first: false,
            bulk_form_id: "public-photo-bulk-form",
            stream_target_photo_id: @stream_target_photo_id,
            next_cursor: @next_cursor,
            newer_cursor: @newer_cursor,
            next_page_path: public_photos_path %>
      <%= render "photos/timeline", periods: @timeline_periods, page_path: public_photos_path if @timeline_periods.present? %>
    <% else %>
      <div class="flex min-h-[440px] items-center justify-center rounded-lg border border-dashed border-zinc-300 bg-white p-8 text-center shadow-sm">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-700">Empty</p>
          <h2 class="mt-3 text-2xl font-semibold text-zinc-950">Nothing public yet.</h2>
        </div>
      </div>
    <% end %>
  </main>
</section>
