<% content_for :title, "Imports" %>

<section class="min-h-screen bg-stone-50 text-zinc-950">
  <%= render "shared/site_header" %>

  <main class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-4 border-b border-zinc-200 pb-5 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-700">Imports</p>
        <h1 class="mt-2 text-3xl font-semibold text-zinc-950">Import status</h1>
      </div>

      <div class="w-full max-w-xl rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
        <%= form_with url: imports_path, method: :post, class: "flex flex-col gap-3 sm:flex-row sm:items-end" do |form| %>
          <div class="min-w-0 flex-1">
            <%= form.label :path, "Path", class: "text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500" %>
            <%= form.text_field :path,
                  value: @default_import_path,
                  class: "mt-2 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15" %>
          </div>
          <%= form.submit "Queue import", class: "rounded-lg bg-zinc-950 px-4 py-2 text-sm font-semibold text-white transition hover:bg-teal-800" %>
        <% end %>
      </div>
    </div>

    <div class="mt-6 grid grid-cols-2 gap-3 lg:grid-cols-6">
      <% %w[imported duplicate skipped failed pending].each do |status| %>
        <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500"><%= status %></p>
          <p class="mt-2 text-2xl font-semibold text-zinc-950"><%= number_with_delimiter(@status_counts.fetch(status, 0)) %></p>
        </div>
      <% end %>
      <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">total</p>
        <p class="mt-2 text-2xl font-semibold text-zinc-950"><%= number_with_delimiter(@status_counts.values.sum) %></p>
      </div>
    </div>

    <div class="mt-8 grid gap-6 xl:grid-cols-[1fr_24rem]">
      <section>
        <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-zinc-500">Files</h2>
        <div class="mt-3 overflow-hidden rounded-lg border border-zinc-200 bg-white shadow-sm">
          <% if @totals_by_zip.any? %>
            <table class="w-full text-left text-sm">
              <thead class="border-b border-zinc-200 bg-stone-50 text-xs uppercase tracking-[0.14em] text-zinc-500">
                <tr>
                  <th class="px-4 py-3">Zip</th>
                  <th class="px-4 py-3 text-right">Imported</th>
                  <th class="px-4 py-3 text-right">Duplicate</th>
                  <th class="px-4 py-3 text-right">Failed</th>
                  <th class="px-4 py-3 text-right">Total</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-zinc-100">
                <% @totals_by_zip.sort.each do |zip_path, counts| %>
                  <tr>
                    <td class="max-w-[22rem] truncate px-4 py-3 font-medium text-zinc-900" title="<%= zip_path %>"><%= File.basename(zip_path) %></td>
                    <td class="px-4 py-3 text-right text-zinc-700"><%= number_with_delimiter(counts.fetch("imported", 0)) %></td>
                    <td class="px-4 py-3 text-right text-zinc-700"><%= number_with_delimiter(counts.fetch("duplicate", 0)) %></td>
                    <td class="px-4 py-3 text-right text-rose-800"><%= number_with_delimiter(counts.fetch("failed", 0)) %></td>
                    <td class="px-4 py-3 text-right text-zinc-900"><%= number_with_delimiter(counts.values.sum) %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          <% else %>
            <div class="p-6 text-sm text-zinc-600">No import records yet.</div>
          <% end %>
        </div>
      </section>

      <aside class="space-y-6">
        <section>
          <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-zinc-500">Runs</h2>
          <div class="mt-3 rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <% if @import_runs.any? %>
              <ul class="space-y-4">
                <% @import_runs.each do |run| %>
                  <li class="text-sm">
                    <div class="flex items-start justify-between gap-3">
                      <p class="min-w-0 truncate font-medium text-zinc-950" title="<%= run.path %>"><%= run.path %></p>
                      <span class="shrink-0 rounded-lg border border-zinc-200 bg-stone-50 px-2 py-1 text-xs font-semibold uppercase tracking-[0.12em] text-zinc-600"><%= run.status %></span>
                    </div>
                    <% if run.summary.present? %>
                      <p class="mt-2 text-xs leading-5 text-zinc-600">
                        <%= run.summary.sort.map { |key, value| "#{key}: #{value}" }.join(" · ") %>
                      </p>
                    <% end %>
                    <% if run.error.present? %>
                      <p class="mt-2 break-words text-xs leading-5 text-rose-800"><%= run.error %></p>
                    <% end %>
                    <p class="mt-2 text-xs text-zinc-500">
                      <%= run.started_at&.to_fs(:short) || run.created_at.to_fs(:short) %>
                      <% if run.finished_at.present? && run.started_at.present? %>
                        · <%= distance_of_time_in_words(run.started_at, run.finished_at) %>
                      <% end %>
                    </p>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-sm text-zinc-600">No runs yet.</p>
            <% end %>
          </div>
        </section>

        <section>
          <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-zinc-500">Recent failures</h2>
          <div class="mt-3 rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <% if @recent_failures.any? %>
              <ul class="space-y-3">
                <% @recent_failures.each do |record| %>
                  <li class="text-sm">
                    <p class="truncate font-medium text-zinc-950" title="<%= record.entry_name %>"><%= record.original_filename || File.basename(record.entry_name) %></p>
                    <p class="mt-1 break-words text-xs leading-5 text-rose-800"><%= record.error %></p>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-sm text-zinc-600">No failures recorded.</p>
            <% end %>
          </div>
        </section>

        <section>
          <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-zinc-500">Recent activity</h2>
          <div class="mt-3 rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
            <% if @recent_imports.any? %>
              <ul class="space-y-3">
                <% @recent_imports.each do |record| %>
                  <li class="flex items-start justify-between gap-3 text-sm">
                    <span class="min-w-0 truncate text-zinc-900" title="<%= record.entry_name %>"><%= record.original_filename || File.basename(record.entry_name) %></span>
                    <span class="shrink-0 rounded-lg border border-zinc-200 bg-stone-50 px-2 py-1 text-xs font-semibold uppercase tracking-[0.12em] text-zinc-600"><%= record.status %></span>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-sm text-zinc-600">No activity recorded.</p>
            <% end %>
          </div>
        </section>
      </aside>
    </div>
  </main>
</section>
