<% content_for :title, "Locations" %>

<section class="min-h-screen bg-stone-50 text-zinc-950">
  <%= render "shared/site_header" %>

  <main class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-4 border-b border-zinc-200 pb-5 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <%= link_to "< Stream", root_path, class: "text-xs font-semibold uppercase tracking-[0.18em] text-teal-700 transition hover:text-teal-900" %>
        <h1 class="mt-3 text-3xl font-semibold text-zinc-950">Locations</h1>
        <p class="mt-1 text-sm text-zinc-600"><%= pluralize(@locations.size, "photo location") %></p>
      </div>

      <%= link_to "Map",
            map_path,
            class: "rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-800 shadow-sm transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
    </div>

    <% if @locations.any? %>
      <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
        <% @locations.each do |location| %>
          <% cover = @location_covers[location.representative_photo_id.to_i] %>
          <article class="group overflow-hidden rounded-lg border border-zinc-200 bg-white shadow-sm transition hover:border-zinc-950">
            <%= link_to location_path(location.id), class: "block" do %>
              <div class="aspect-[4/3] bg-zinc-900">
                <% if cover %>
                  <%= photo_stream_media(cover) %>
                <% else %>
                  <div class="flex size-full items-center justify-center text-xs font-semibold uppercase tracking-[0.18em] text-white/70">Location</div>
                <% end %>
              </div>
              <div class="p-4">
                <h2 class="truncate text-lg font-semibold text-zinc-950"><%= location.title %></h2>
                <p class="mt-1 text-sm text-zinc-600"><%= media_count_label(photo_count: location.image_count.to_i, video_count: location.video_count.to_i) %></p>
                <p class="mt-3 text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">
                  <%= photo_stream_day_label(location.oldest_at.to_date) %> - <%= photo_stream_day_label(location.newest_at.to_date) %>
                </p>
              </div>
            <% end %>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="mt-6 flex min-h-[340px] items-center justify-center rounded-lg border border-dashed border-zinc-300 bg-white p-8 text-center shadow-sm">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-700">No locations</p>
          <h2 class="mt-3 text-2xl font-semibold text-zinc-950">No geotagged photos yet.</h2>
        </div>
      </div>
    <% end %>
  </main>
</section>
