<% content_for :title, @location_title %>

<% if current_user&.owner? %>
  <% content_for :header_actions do %>
    <%= render "photos/bulk_toolbar", albums: @albums, return_to: location_path(@location_id), form_id: "location-photo-bulk-form" %>
  <% end %>
<% end %>

<section class="min-h-screen bg-stone-50 text-zinc-950"
         <%= %(data-controller="bulk-selection" data-bulk-selection-form-id-value="location-photo-bulk-form" data-bulk-selection-empty-label-value="Select photos, then choose an action.").html_safe if current_user&.owner? %>>
  <%= render "shared/site_header" %>

  <main class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="mb-6 flex flex-col gap-4 border-b border-zinc-200 pb-5 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <%= link_to "< Locations", locations_path, class: "text-xs font-semibold uppercase tracking-[0.18em] text-teal-700 transition hover:text-teal-900" %>
        <h1 class="mt-3 text-3xl font-semibold text-zinc-950"><%= @location_title %></h1>
        <p class="mt-1 text-sm text-zinc-600"><%= pluralize(@location_row.photo_count.to_i, "photo") %></p>
      </div>

      <%= link_to "Map",
            map_path,
            class: "rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-800 shadow-sm transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
    </div>

    <%= render "photos/grid",
          photos: @photos,
          return_to: location_path(@location_id),
          feature_first: false,
          bulk_form_id: "location-photo-bulk-form",
          next_cursor: @next_cursor,
          next_page_path: location_path(@location_id) %>
  </main>
</section>
