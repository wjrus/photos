<header class="sticky top-0 z-40 border-b border-zinc-200 bg-stone-50/90 px-4 py-3 backdrop-blur sm:px-6 lg:px-8">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4">
    <details class="group relative" data-controller="menu">
      <summary class="cursor-pointer list-none rounded-lg px-2 py-1 transition hover:bg-white hover:shadow-sm"
               title="Open site navigation"
               aria-label="Open site navigation">
        <span class="block text-xs font-semibold uppercase tracking-[0.24em] text-teal-700">William Rockwood</span>
        <span class="block text-xl font-semibold text-zinc-950">wjr photos</span>
      </summary>
      <nav class="absolute left-0 z-30 mt-3 w-[min(90vw,240px)] rounded-lg border border-zinc-200 bg-white p-2 shadow-2xl" aria-label="Site navigation">
        <%= link_to "Stream",
              root_path,
              class: "block rounded-lg px-3 py-2 text-sm font-semibold text-zinc-800 transition hover:bg-zinc-950 hover:text-white" %>
        <%= link_to "Albums",
              albums_path,
              class: "block rounded-lg px-3 py-2 text-sm font-semibold text-zinc-800 transition hover:bg-zinc-950 hover:text-white" %>
        <% if privileged_metadata_viewer? %>
          <%= link_to "Map",
                map_path,
                class: "block rounded-lg px-3 py-2 text-sm font-semibold text-zinc-800 transition hover:bg-zinc-950 hover:text-white" %>
        <% end %>
      </nav>
    </details>

    <div class="flex items-center gap-2">
      <%= yield :header_actions %>

      <% if signed_in? %>
        <details class="group relative" data-controller="menu">
          <summary class="flex cursor-pointer list-none items-center rounded-lg border border-zinc-200 bg-white p-1 shadow-sm transition hover:border-zinc-950"
                   title="Open account menu"
                   aria-label="Open account menu">
            <%= user_avatar(current_user) %>
          </summary>
          <div class="absolute right-0 z-30 mt-3 w-[min(90vw,260px)] rounded-lg border border-zinc-200 bg-white p-2 shadow-2xl">
            <% if current_user&.owner? %>
              <%= link_to "Upload",
                    uploads_path,
                    class: "block rounded-lg px-3 py-2 text-sm font-semibold text-zinc-800 transition hover:bg-zinc-950 hover:text-white" %>
              <%= link_to "Imports",
                    imports_path,
                    class: "block rounded-lg px-3 py-2 text-sm font-semibold text-zinc-800 transition hover:bg-zinc-950 hover:text-white" %>
              <%= link_to "Users",
                    users_path,
                    class: "block rounded-lg px-3 py-2 text-sm font-semibold text-zinc-800 transition hover:bg-zinc-950 hover:text-white" %>
              <div class="my-2 border-t border-zinc-200"></div>
            <% end %>
            <%= button_to "Sign out", sign_out_path, method: :delete, class: "w-full rounded-lg border border-zinc-300 px-4 py-2 text-sm font-medium text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
          </div>
        </details>
      <% else %>
        <%= link_to "Sign in", sign_in_path, class: "rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-medium text-zinc-800 shadow-sm transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
      <% end %>
    </div>
  </div>
</header>
