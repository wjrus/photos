<header class="sticky top-0 z-40 border-b border-zinc-200 bg-stone-50/90 px-4 py-3 backdrop-blur sm:px-6 lg:px-8">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4">
    <div class="flex min-w-0 items-center gap-3">
      <details class="group relative" data-controller="menu">
        <summary class="flex size-11 cursor-pointer list-none items-center justify-center rounded-lg border border-zinc-200 bg-white text-zinc-800 shadow-sm transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white"
                 title="Site navigation"
                 aria-label="Site navigation">
          <%= app_icon(:menu, classes: "size-5") %>
        </summary>
        <nav class="absolute left-0 z-30 mt-3 w-[min(90vw,240px)] rounded-lg border border-zinc-200 bg-white p-2 shadow-2xl" aria-label="Site navigation">
          <%= link_to "Stream",
                root_path,
                class: "block rounded-lg px-3 py-2 text-sm font-semibold text-zinc-800 transition hover:bg-zinc-950 hover:text-white" %>
          <%= link_to "Albums",
                albums_path,
                class: "block rounded-lg px-3 py-2 text-sm font-semibold text-zinc-800 transition hover:bg-zinc-950 hover:text-white" %>
          <%= link_to "Search",
                search_path,
                class: "block rounded-lg px-3 py-2 text-sm font-semibold text-zinc-800 transition hover:bg-zinc-950 hover:text-white" %>
          <% if current_user&.owner? %>
            <%= link_to "Public",
                  public_photos_path,
                  class: "block rounded-lg px-3 py-2 text-sm font-semibold text-zinc-800 transition hover:bg-zinc-950 hover:text-white" %>
            <%= link_to "Archive",
                  archived_photos_path,
                  class: "block rounded-lg px-3 py-2 text-sm font-semibold text-zinc-800 transition hover:bg-zinc-950 hover:text-white" %>
          <% end %>
          <% if privileged_metadata_viewer? %>
            <%= link_to "Locations",
                  locations_path,
                  class: "block rounded-lg px-3 py-2 text-sm font-semibold text-zinc-800 transition hover:bg-zinc-950 hover:text-white" %>
            <%= link_to "Map",
                  map_path,
                  class: "block rounded-lg px-3 py-2 text-sm font-semibold text-zinc-800 transition hover:bg-zinc-950 hover:text-white" %>
          <% end %>
        </nav>
      </details>

      <%= link_to root_path, class: "min-w-0 rounded-lg px-1 py-1 transition hover:bg-white hover:shadow-sm", aria: { label: "wjr photos home" } do %>
        <span class="block text-xs font-semibold uppercase tracking-[0.24em] text-teal-700">William Rockwood</span>
        <span class="block text-xl font-semibold text-zinc-950">wjr photos</span>
      <% end %>
    </div>

    <div class="flex items-center gap-2">
      <%= yield :header_actions %>

      <% if signed_in? %>
        <details class="group relative" data-controller="menu">
          <summary class="flex cursor-pointer list-none items-center rounded-lg border border-zinc-200 bg-white p-1 shadow-sm transition hover:border-zinc-950"
                   title="Account menu"
                   aria-label="Account menu">
            <span class="relative block">
              <%= user_avatar(current_user) %>
              <% if repository_unread_event_count.positive? %>
                <span class="absolute -right-2 -top-2 grid min-w-5 place-items-center rounded-full border-2 border-white bg-rose-700 px-1 text-xs font-bold leading-4 text-white">
                  <%= repository_unread_event_count > 9 ? "9+" : repository_unread_event_count %>
                </span>
              <% end %>
            </span>
          </summary>
          <div class="absolute right-0 z-30 mt-3 w-[min(90vw,260px)] rounded-lg border border-zinc-200 bg-white p-2 shadow-2xl">
            <% if current_user&.owner? %>
              <%= link_to "Upload",
                    uploads_path,
                    class: "block rounded-lg px-3 py-2 text-sm font-semibold text-zinc-800 transition hover:bg-zinc-950 hover:text-white" %>
              <%= link_to "Imports",
                    imports_path,
                    class: "block rounded-lg px-3 py-2 text-sm font-semibold text-zinc-800 transition hover:bg-zinc-950 hover:text-white" %>
              <%= link_to repository_status_path,
                    class: "flex items-center justify-between gap-3 rounded-lg px-3 py-2 text-sm font-semibold text-zinc-800 transition hover:bg-zinc-950 hover:text-white" do %>
                <span>Repository status</span>
                <% if repository_unread_event_count.positive? %>
                  <span class="rounded-full bg-rose-700 px-2 py-0.5 text-xs font-bold text-white"><%= repository_unread_event_count %></span>
                <% end %>
              <% end %>
              <%= link_to "Users",
                    users_path,
                    class: "block rounded-lg px-3 py-2 text-sm font-semibold text-zinc-800 transition hover:bg-zinc-950 hover:text-white" %>
              <%= button_to user_preferences_path,
                    method: :patch,
                    params: {
                      return_to: request.fullpath,
                      user: { show_stream_metadata: !current_user.show_stream_metadata? }
                    },
                    class: "flex w-full items-center justify-between gap-3 rounded-lg px-3 py-2 text-left text-sm font-semibold text-zinc-800 transition hover:bg-zinc-950 hover:text-white" do %>
                <span>Show metadata</span>
                <span class="rounded-full border px-2 py-0.5 text-[0.65rem] uppercase tracking-[0.16em] <%= current_user.show_stream_metadata? ? "border-teal-200 bg-teal-50 text-teal-900" : "border-zinc-200 bg-zinc-50 text-zinc-500" %>">
                  <%= current_user.show_stream_metadata? ? "On" : "Off" %>
                </span>
              <% end %>
              <div class="rounded-lg px-3 py-2">
                <div class="text-xs font-semibold uppercase tracking-[0.16em] text-zinc-500">Stream size</div>
                <div class="mt-2 grid grid-cols-3 gap-1">
                  <% User::STREAM_TILE_SIZES.each do |size| %>
                    <%= button_to photo_stream_tile_label(size),
                          user_preferences_path,
                          method: :patch,
                          params: {
                            return_to: request.fullpath,
                            user: { stream_tile_size: size }
                          },
                          form: { class: "contents" },
                          class: "rounded-md border px-2 py-1.5 text-xs font-semibold transition #{current_user.stream_tile_size == size ? "border-zinc-950 bg-zinc-950 text-white" : "border-zinc-200 bg-white text-zinc-700 hover:border-zinc-950 hover:bg-zinc-950 hover:text-white"}" %>
                  <% end %>
                </div>
              </div>
              <div class="my-2 border-t border-zinc-200"></div>
            <% end %>
            <label class="theme-picker" aria-label="Theme">
              <span class="theme-picker__label">Theme</span>
              <select class="theme-picker__select" data-theme-select>
                <option value="system">System</option>
                <option value="light">Light</option>
                <option value="dark">Dark</option>
                <option value="paper">Paper</option>
                <option value="terminal">Terminal</option>
                <option value="amber">Amber</option>
              </select>
            </label>
            <div class="my-2 border-t border-zinc-200"></div>
            <%= button_to "Sign out", sign_out_path, method: :delete, class: "w-full rounded-lg border border-zinc-300 px-4 py-2 text-sm font-medium text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
          </div>
        </details>
      <% else %>
        <label class="theme-picker hidden sm:grid" aria-label="Theme">
          <span class="theme-picker__label">Theme</span>
          <select class="theme-picker__select" data-theme-select>
            <option value="system">System</option>
            <option value="light">Light</option>
            <option value="dark">Dark</option>
            <option value="paper">Paper</option>
            <option value="terminal">Terminal</option>
            <option value="amber">Amber</option>
          </select>
        </label>
        <%= link_to "Sign in", sign_in_path, class: "rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-medium text-zinc-800 shadow-sm transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
      <% end %>
    </div>
  </div>
</header>
