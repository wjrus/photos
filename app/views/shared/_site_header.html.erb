<header class="sticky top-0 z-40 border-b border-zinc-200 bg-stone-50/90 px-4 py-3 backdrop-blur sm:px-6 lg:px-8">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4">
    <%= link_to root_path, class: "px-2 py-1" do %>
      <span class="block text-xs font-semibold uppercase tracking-[0.24em] text-teal-700">William Rockwood</span>
      <span class="block text-xl font-semibold text-zinc-950">wjr photos</span>
    <% end %>

    <div class="flex items-center gap-3">
      <% if privileged_metadata_viewer? %>
        <%= link_to "Map",
              map_path,
              class: "rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-800 shadow-sm transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
      <% end %>

      <% if current_user&.owner? %>
        <%= link_to "Upload",
              uploads_path,
              class: "rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-800 shadow-sm transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
      <% end %>

      <% if signed_in? %>
        <details class="group relative" data-controller="menu">
          <summary class="flex cursor-pointer list-none items-center gap-3 rounded-lg border border-zinc-200 bg-white px-3 py-2 shadow-sm transition hover:border-zinc-950">
            <% if current_user.avatar_url.present? %>
              <%= image_tag current_user.avatar_url, alt: "", class: "size-9 rounded-lg border border-zinc-200" %>
            <% else %>
              <span class="flex size-9 items-center justify-center rounded-lg bg-zinc-950 text-sm font-semibold text-white"><%= current_user.display_name.first.upcase %></span>
            <% end %>
            <span class="hidden text-left sm:block">
              <span class="block text-sm font-semibold text-zinc-950"><%= current_user.display_name %></span>
              <span class="block text-xs uppercase tracking-[0.16em] text-zinc-500"><%= current_user.role %></span>
            </span>
          </summary>
          <div class="absolute right-0 z-30 mt-3 w-[min(90vw,260px)] rounded-lg border border-zinc-200 bg-white p-3 shadow-2xl">
            <%= button_to "Sign out", sign_out_path, method: :delete, class: "w-full rounded-lg border border-zinc-300 px-4 py-2 text-sm font-medium text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
          </div>
        </details>
      <% else %>
        <%= button_to "Sign in", "/auth/google_oauth2", method: :post, data: { turbo: false }, class: "rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-medium text-zinc-800 shadow-sm transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
      <% end %>
    </div>
  </div>
</header>
