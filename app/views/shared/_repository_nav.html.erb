<% links = [
  [ "Overview", repository_status_path ],
  [ "Queues", queue_status_path ],
  [ "File health", repository_health_path ]
] %>

<nav class="mt-5 flex flex-wrap gap-2" aria-label="Repository status sections">
  <% links.each do |label, path| %>
    <% active = current_page?(path) %>
    <%= link_to label,
          path,
          aria: { current: ("page" if active) },
          class: [
            "inline-flex items-center justify-center rounded-lg border px-4 py-2 text-sm font-semibold shadow-sm transition",
            active ? "border-zinc-950 bg-zinc-950 text-white" : "border-zinc-300 bg-white text-zinc-800 hover:border-zinc-950 hover:bg-zinc-950 hover:text-white"
          ].join(" ") %>
  <% end %>
</nav>
