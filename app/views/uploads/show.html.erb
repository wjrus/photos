<% content_for :title, "Upload photos" %>

<section class="min-h-screen bg-stone-50 text-zinc-950">
  <%= render "shared/site_header" %>

  <main class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="mb-6 flex items-end justify-between gap-4">
      <div>
        <%= link_to "Back to stream", root_path, class: "text-xs font-semibold uppercase tracking-[0.18em] text-teal-700 transition hover:text-teal-900" %>
        <h1 class="mt-3 text-3xl font-semibold text-zinc-950">Upload</h1>
      </div>
    </div>

    <%= form_with scope: :photos, url: photos_path, class: "space-y-4", data: { controller: "drop-upload", action: "submit->drop-upload#submit", turbo: false } do |form| %>
      <%= hidden_field_tag :return_to, uploads_path %>
      <div class="flex min-h-[440px] cursor-pointer items-center justify-center rounded-lg border border-dashed border-zinc-300 bg-white p-8 text-center shadow-sm transition hover:border-teal-700 hover:bg-teal-50"
           data-action="click->drop-upload#browse dragover->drop-upload#dragover dragleave->drop-upload#dragleave drop->drop-upload#drop">
        <div class="max-w-lg">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-700">Import</p>
          <h2 class="mt-3 text-2xl font-semibold text-zinc-950">Drop files here</h2>
          <p class="mt-3 text-sm leading-6 text-zinc-600" data-drop-upload-target="summary">Choose files or drag an iPhone import batch into this window.</p>
          <p class="mt-4 text-xs uppercase tracking-[0.16em] text-zinc-400">HEIC JPG PNG MOV MP4 AAE</p>
          <div class="mt-6 flex items-center justify-center gap-2" data-drop-upload-ignore-browse data-action="click->drop-upload#stop">
            <button type="button" class="rounded-lg border border-zinc-300 px-4 py-2 text-sm font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" data-action="drop-upload#browse">Choose</button>
            <%= form.submit "Upload",
                  disabled: true,
                  class: "rounded-lg bg-teal-700 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-teal-800 disabled:cursor-not-allowed disabled:bg-zinc-300",
                  data: { drop_upload_target: "submit" } %>
          </div>
          <%= form.file_field :files,
                multiple: true,
                accept: ".heic,.heif,.jpg,.jpeg,.png,.mov,.mp4,.aae,image/heic,image/heif,image/jpeg,image/png,video/quicktime,video/mp4",
                class: "hidden",
                data: { drop_upload_target: "input", action: "change->drop-upload#choose" } %>
        </div>
      </div>
    <% end %>

    <% if @failed_drive_archive_count.positive? %>
      <section class="mt-6 rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
        <div class="flex items-center justify-between gap-4">
          <div>
            <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Drive failures</h2>
            <p class="mt-1 text-sm text-zinc-700"><%= @failed_drive_archive_count %></p>
          </div>
          <%= button_to "Retry all",
                retry_failed_archives_photos_path,
                method: :post,
                class: "rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
        </div>
      </section>
    <% end %>
  </main>
</section>
