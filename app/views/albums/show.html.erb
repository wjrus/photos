<% content_for :title, @album.title %>
<% content_for :body_class, "stream-timeline-scrollbar" if @timeline_periods.present? %>

<% if current_user&.owner? %>
  <% content_for :header_actions do %>
    <%= render "photos/bulk_toolbar", albums: @albums, return_to: album_path(@album), form_id: "album-photo-bulk-form", album: @album %>
  <% end %>
<% end %>

<section class="min-h-screen bg-stone-50 text-zinc-950"
         <%= %(data-controller="bulk-selection" data-bulk-selection-form-id-value="album-photo-bulk-form" data-bulk-selection-empty-label-value="Select photos, then choose an action.").html_safe if current_user&.owner? %>>
  <%= render "shared/site_header" %>

  <main class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-4 border-b border-zinc-200 pb-5 sm:flex-row sm:items-end sm:justify-between">
      <div class="min-w-0">
        <%= link_to "Back to albums", albums_path, class: "text-xs font-semibold uppercase tracking-[0.18em] text-teal-700 transition hover:text-teal-900" %>
        <h1 class="mt-3 truncate text-3xl font-semibold text-zinc-950"><%= @album.title %></h1>
        <p class="mt-1 text-sm text-zinc-600"><%= media_count_label(photo_count: @visible_media_count[:photos], video_count: @visible_media_count[:videos]) %><% if current_user&.owner? %> · <%= @album.visibility %><% end %></p>
      </div>

      <% if current_user&.owner? %>
        <details class="relative" data-controller="menu">
          <summary class="cursor-pointer list-none rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-800 shadow-sm transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white">
            Album info
          </summary>
          <div class="absolute right-0 z-30 mt-3 w-[min(92vw,420px)] max-h-[calc(100vh-9rem)] overflow-y-auto rounded-lg border border-zinc-200 bg-white p-5 shadow-2xl">
            <div class="space-y-5">
              <section>
                <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Summary</h2>
                <p class="mt-2 text-sm text-zinc-700"><%= media_count_label(photo_count: @visible_media_count[:photos], video_count: @visible_media_count[:videos]) %> · <%= @album.visibility %></p>
                <p class="mt-1 text-xs text-zinc-500">Updated <%= time_ago_in_words(@album.updated_at) %> ago</p>
              </section>

              <section class="border-t border-zinc-200 pt-5"
                       data-controller="album-download"
                       data-album-download-create-url-value="<%= album_downloads_path(album_id: @album.id) %>">
                <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Download</h2>
                <div class="mt-3 flex flex-wrap items-center gap-2">
                  <button type="button"
                          class="rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white disabled:cursor-wait disabled:opacity-70"
                          data-album-download-target="button"
                          data-action="album-download#start">
                    Download ZIP
                  </button>
                  <a href="#"
                     hidden
                     class="rounded-lg bg-zinc-950 px-4 py-2 text-sm font-semibold text-white transition hover:bg-teal-800"
                     data-album-download-target="link"
                     data-turbo="false">
                    Save ZIP
                  </a>
                </div>
                <div class="mt-3" hidden data-album-download-target="progress">
                  <div class="mb-1 text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500" data-album-download-target="status">Preparing ZIP...</div>
                  <div class="h-2 overflow-hidden rounded-full bg-zinc-200">
                    <div class="h-full w-0 rounded-full bg-teal-700 transition-[width]" data-album-download-target="bar"></div>
                  </div>
                </div>
              </section>

              <section class="border-t border-zinc-200 pt-5">
                <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Edit</h2>
                <%= form_with model: @album, url: album_path(@album), method: :patch, class: "mt-3 space-y-3" do |form| %>
                  <div>
                    <%= form.label :title, "Name", class: "text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500" %>
                    <%= form.text_field :title, class: "mt-2 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15", required: true %>
                  </div>
                  <div>
                    <%= form.label :visibility, "Visibility", class: "text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500" %>
                    <%= form.select :visibility, [["Private", "private"], ["Public", "public"]], {}, class: "mt-2 w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15" %>
                  </div>
                  <%= form.submit "Save", class: "w-full rounded-lg bg-zinc-950 px-3 py-2 text-sm font-semibold text-white transition hover:bg-teal-800" %>
                <% end %>
              </section>

              <section class="border-t border-zinc-200 pt-5">
                <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Sharing</h2>
                <% if @album_shares.any? %>
                  <div class="mt-3 space-y-2">
                    <% @album_shares.each do |share| %>
                      <div class="flex items-center justify-between gap-3 rounded-lg border border-zinc-200 bg-stone-50 px-3 py-2">
                        <div class="min-w-0">
                          <p class="truncate text-sm font-semibold text-zinc-900"><%= share.user.display_name %></p>
                          <p class="truncate text-xs text-zinc-500"><%= share.user.email %></p>
                        </div>
                        <%= button_to "Remove",
                              album_share_path(share),
                              method: :delete,
                              class: "rounded-lg border border-rose-200 px-3 py-2 text-xs font-semibold text-rose-800 transition hover:bg-rose-800 hover:text-white" %>
                      </div>
                    <% end %>
                  </div>
                <% else %>
                  <p class="mt-3 text-sm text-zinc-500">Not shared with anyone.</p>
                <% end %>

                <% if @shareable_users.any? %>
                  <%= form_with url: album_album_shares_path(@album), method: :post, class: "mt-3 flex gap-2" do %>
                    <label for="album_share_user_id" class="sr-only">Share with</label>
                    <select id="album_share_user_id"
                            name="user_id"
                            class="min-w-0 flex-1 rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15">
                      <% @shareable_users.each do |user| %>
                        <option value="<%= user.id %>"><%= user.display_name %></option>
                      <% end %>
                    </select>
                    <button type="submit"
                            class="rounded-lg bg-zinc-950 px-3 py-2 text-sm font-semibold text-white transition hover:bg-teal-800">
                      Share
                    </button>
                  <% end %>
                <% end %>
              </section>

              <section class="border-t border-zinc-200 pt-5">
                <% if @album.public? %>
                  <%= button_to "Make private",
                        unpublish_album_path(@album),
                        method: :patch,
                        class: "w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
                <% else %>
                  <%= button_to "Publish",
                        publish_album_path(@album),
                        method: :patch,
                        class: "w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
                <% end %>

                <div class="mt-3" data-controller="confirm-modal" data-action="keydown@window->confirm-modal#keydown">
                  <button type="button"
                          class="w-full rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm font-semibold text-rose-900 transition hover:bg-rose-800 hover:text-white"
                          data-action="confirm-modal#open">
                    Delete album
                  </button>

                  <div class="fixed inset-0 z-50 hidden items-center justify-center bg-zinc-950/65 p-4 backdrop-blur-sm"
                       role="dialog"
                       aria-modal="true"
                       aria-labelledby="delete-album-title"
                       data-confirm-modal-target="dialog"
                       data-action="click->confirm-modal#backdrop">
                    <div class="w-full max-w-sm rounded-lg border border-rose-200 bg-white p-5 text-zinc-950 shadow-2xl"
                         data-confirm-modal-target="panel">
                      <h3 id="delete-album-title" class="text-lg font-semibold text-zinc-950">Delete <%= @album.title %>?</h3>
                      <p class="mt-3 text-sm leading-6 text-zinc-600">
                        This removes the album and its memberships. The photos stay in your library.
                      </p>
                      <div class="mt-5 grid grid-cols-2 gap-3">
                        <button type="button"
                                class="rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold uppercase text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white"
                                data-action="confirm-modal#close">
                          Cancel
                        </button>
                        <%= button_to "Delete",
                              album_path(@album),
                              method: :delete,
                              class: "w-full rounded-lg bg-rose-800 px-3 py-2 text-xs font-semibold uppercase text-white transition hover:bg-rose-950" %>
                      </div>
                    </div>
                  </div>
                </div>
              </section>
            </div>
          </div>
        </details>
      <% end %>
    </div>

    <div class="mt-6">
      <% if @photos.any? %>
        <%= render "photos/grid",
              photos: @photos,
              return_to: album_path(@album),
              feature_first: false,
              bulk_form_id: "album-photo-bulk-form",
              album: @album,
              group_by_day: false,
              stream_target_photo_id: @stream_target_photo_id,
              next_cursor: @next_cursor,
              newer_cursor: @newer_cursor,
              next_page_path: album_path(@album) %>
        <%= render "photos/timeline", periods: @timeline_periods, page_path: album_path(@album) if @timeline_periods.present? %>
      <% else %>
        <div class="flex min-h-[340px] items-center justify-center rounded-lg border border-dashed border-zinc-300 bg-white p-8 text-center shadow-sm">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-700">Empty</p>
            <h2 class="mt-3 text-2xl font-semibold text-zinc-950">No visible photos in this album.</h2>
          </div>
        </div>
      <% end %>
    </div>
  </main>
</section>
