<%= form_with url: album_bulk_actions_path, method: :post, html: { id: form_id, class: "sticky top-[73px] z-30 mt-6 rounded-lg border border-zinc-200 bg-white/95 p-3 shadow-sm backdrop-blur" } do %>
  <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-700">Selection</p>
      <p class="mt-1 text-sm text-zinc-600">Check albums, then choose an action.</p>
    </div>

    <div class="flex flex-wrap items-center gap-2">
      <button type="submit"
              name="bulk_action"
              value="publish"
              class="rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white">
        Publish
      </button>
      <button type="submit"
              name="bulk_action"
              value="unpublish"
              class="rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white">
        Make private
      </button>

      <div data-controller="confirm-modal" data-action="keydown@window->confirm-modal#keydown">
        <button type="button"
                class="rounded-lg border border-rose-200 px-3 py-2 text-xs font-semibold text-rose-800 transition hover:bg-rose-800 hover:text-white"
                data-action="confirm-modal#open">
          Remove
        </button>

        <div class="fixed inset-0 z-50 hidden items-center justify-center bg-zinc-950/65 p-4 backdrop-blur-sm"
             role="dialog"
             aria-modal="true"
             aria-labelledby="remove-selected-albums-title"
             data-confirm-modal-target="dialog"
             data-action="click->confirm-modal#backdrop">
          <div class="w-full max-w-sm rounded-lg border border-rose-200 bg-white p-5 shadow-2xl"
               data-confirm-modal-target="panel">
            <h3 id="remove-selected-albums-title" class="text-lg font-semibold text-zinc-950">Remove selected albums?</h3>
            <p class="mt-3 text-sm leading-6 text-zinc-600">
              This removes the album containers. Photos stay in the stream.
            </p>
            <div class="mt-5 grid grid-cols-2 gap-3">
              <button type="button"
                      class="rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold uppercase text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white"
                      data-action="confirm-modal#close">
                Cancel
              </button>
              <button type="submit"
                      name="bulk_action"
                      value="delete"
                      class="rounded-lg bg-rose-800 px-3 py-2 text-xs font-semibold uppercase text-white transition hover:bg-rose-950">
                Remove
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
