<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
  <% albums.each do |album| %>
    <% cover = @album_covers[album.id] %>
    <% visible_count = @visible_media_counts.fetch(album.id, { photos: 0, videos: 0 }) %>
    <article class="group relative overflow-hidden rounded-lg border border-zinc-200 bg-white shadow-sm transition hover:border-zinc-950" data-bulk-selection-card>
      <% if current_user&.owner? %>
        <label class="selection-control absolute left-3 top-3 z-20 cursor-pointer"
               title="Select"
               data-action="change->bulk-selection#update">
          <%= check_box_tag "album_ids[]", album.id, false, form: "album-bulk-form", aria: { label: "Select #{album.title}" } %>
          <span class="selection-circle">✓</span>
        </label>
      <% end %>

      <%= link_to album_path(album),
            class: "block",
            data: current_user&.owner? ? { action: "click->bulk-selection#toggleCard" } : {} do %>
        <div class="aspect-[4/3] bg-zinc-900">
          <% if cover %>
            <%= photo_stream_media(cover) %>
          <% else %>
            <div class="flex size-full items-center justify-center text-xs font-semibold uppercase tracking-[0.18em] text-white/70">Empty</div>
          <% end %>
        </div>
        <div class="flex items-start justify-between gap-4 p-4">
          <div class="min-w-0">
            <h2 class="truncate text-lg font-semibold text-zinc-950"><%= album.title %></h2>
            <p class="mt-1 text-sm text-zinc-600"><%= media_count_label(photo_count: visible_count[:photos], video_count: visible_count[:videos]) %></p>
          </div>
          <% if current_user&.owner? %>
            <span class="shrink-0 rounded-lg border border-zinc-200 bg-stone-50 px-2 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-zinc-600"><%= album.visibility %></span>
          <% end %>
        </div>
      <% end %>
    </article>
  <% end %>
</div>

<% if @next_album_page.present? %>
  <div data-infinite-scroll-target="sentinel"
       data-next-url="<%= albums_path(sort: @album_sort, page: @next_album_page) %>"
       class="py-8 text-center text-sm font-semibold text-zinc-500">
    Loading more albums...
  </div>
<% end %>
