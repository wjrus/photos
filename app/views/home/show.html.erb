<% content_for :title, "wjr photos" %>

<section class="min-h-screen bg-stone-50 text-zinc-950">
  <header class="sticky top-0 z-40 border-b border-zinc-200 bg-stone-50/90 px-4 py-3 backdrop-blur sm:px-6 lg:px-8">
    <div class="mx-auto flex max-w-7xl items-center justify-between gap-4">
      <details class="group relative" data-controller="menu">
        <summary class="flex cursor-pointer list-none items-center gap-3 rounded-lg px-2 py-1 transition hover:bg-white">
          <span>
            <span class="block text-xs font-semibold uppercase tracking-[0.24em] text-teal-700">William Rockwood</span>
            <span class="block text-xl font-semibold text-zinc-950">wjr photos</span>
          </span>
        </summary>
        <div class="absolute left-0 z-30 mt-3 w-[min(90vw,340px)] rounded-lg border border-zinc-200 bg-white p-4 shadow-2xl">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Originals</p>
            <p class="mt-2 text-sm leading-6 text-zinc-700">Preserved privately.</p>
          </div>
          <div class="mt-4 border-t border-zinc-200 pt-4">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Public</p>
            <p class="mt-2 text-sm leading-6 text-zinc-700">Scrubbed display copies.</p>
          </div>
          <div class="mt-4 border-t border-zinc-200 pt-4">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Details</p>
            <p class="mt-2 text-sm leading-6 text-zinc-700">Owner and trusted viewers only.</p>
          </div>
        </div>
      </details>

      <% if signed_in? %>
        <details class="group relative" data-controller="menu">
          <summary class="flex cursor-pointer list-none items-center gap-3 rounded-lg border border-zinc-200 bg-white px-3 py-2 shadow-sm transition hover:border-zinc-950">
            <% if current_user.avatar_url.present? %>
              <%= image_tag current_user.avatar_url, alt: "", class: "size-9 rounded-lg border border-zinc-200" %>
            <% else %>
              <span class="flex size-9 items-center justify-center rounded-lg bg-zinc-950 text-sm font-semibold text-white"><%= current_user.display_name.first.upcase %></span>
            <% end %>
            <span class="hidden text-left sm:block">
              <span class="block text-sm font-semibold text-zinc-950"><%= current_user.display_name %></span>
              <span class="block text-xs uppercase tracking-[0.16em] text-zinc-500"><%= current_user.role %></span>
            </span>
          </summary>
          <div class="absolute right-0 z-30 mt-3 w-[min(90vw,380px)] rounded-lg border border-zinc-200 bg-white p-4 shadow-2xl">
            <% if current_user&.owner? %>
              <%= form_with scope: :photos, url: photos_path, class: "space-y-3", data: { controller: "drop-upload", turbo: false } do |form| %>
                <div class="rounded-lg border border-dashed border-zinc-300 bg-stone-50 p-4 transition"
                     data-action="click->drop-upload#browse dragover->drop-upload#dragover dragleave->drop-upload#dragleave drop->drop-upload#drop">
                  <p class="text-sm font-semibold text-zinc-950">Import from folder</p>
                  <p class="mt-1 text-sm text-zinc-600" data-drop-upload-target="summary">Drop iPhone imports here or choose files.</p>
                  <p class="mt-2 text-xs uppercase tracking-[0.16em] text-zinc-400">HEIC JPG PNG MOV MP4 AAE</p>
                  <div class="mt-4 flex items-center gap-2">
                    <button type="button" class="rounded-lg border border-zinc-300 px-4 py-2 text-sm font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" data-action="drop-upload#browse">Choose</button>
                    <%= form.submit "Upload", disabled: true, class: "rounded-lg bg-teal-700 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-teal-800 disabled:cursor-not-allowed disabled:bg-zinc-300", data: { drop_upload_target: "submit" } %>
                  </div>
                  <%= form.file_field :files, multiple: true, accept: ".heic,.heif,.jpg,.jpeg,.png,.mov,.mp4,.aae,image/heic,image/heif,image/jpeg,image/png,video/quicktime,video/mp4", class: "hidden", data: { drop_upload_target: "input", action: "change->drop-upload#choose" } %>
                </div>
              <% end %>
              <div class="mt-3 rounded-lg border border-zinc-200 bg-white p-3">
                <div class="flex items-center justify-between gap-3">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Drive failures</p>
                    <p class="mt-1 text-sm text-zinc-700"><%= @failed_drive_archive_count %></p>
                  </div>
                  <%= button_to "Retry all",
                        retry_failed_archives_photos_path,
                        method: :post,
                        disabled: @failed_drive_archive_count.zero?,
                        class: "rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white disabled:cursor-not-allowed disabled:border-zinc-200 disabled:text-zinc-400 disabled:hover:bg-white" %>
                </div>
              </div>
            <% end %>
            <%= button_to "Sign out", sign_out_path, method: :delete, class: "mt-3 w-full rounded-lg border border-zinc-300 px-4 py-2 text-sm font-medium text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
          </div>
        </details>
      <% else %>
        <%= button_to "Sign in", "/auth/google_oauth2", method: :post, data: { turbo: false }, class: "rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-medium text-zinc-800 shadow-sm transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
      <% end %>
    </div>
  </header>

  <main class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <% if @photos.any? %>
      <div class="grid auto-rows-[220px] grid-cols-2 gap-3 sm:grid-cols-3 xl:grid-cols-4">
        <% @photos.each_with_index do |photo, index| %>
          <article class="<%= index.zero? ? "col-span-2 row-span-2" : "" %> group relative overflow-hidden rounded-lg bg-zinc-900 shadow-sm">
            <%= link_to photo_path(photo), class: "absolute inset-0 z-10", aria: { label: "View #{photo.title}" } do %>
              <span class="sr-only">View <%= photo.title %></span>
            <% end %>
            <%= photo_stream_media(photo) %>
            <% if photo.video? %>
              <div class="absolute right-3 top-3 rounded-lg bg-black/55 px-2 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-white backdrop-blur">Video</div>
            <% end %>
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent opacity-90"></div>
            <div class="absolute inset-x-0 bottom-0 p-4 text-white">
              <div class="flex items-center justify-between gap-3">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.18em] opacity-75"><%= photo.visibility %></p>
                  <h2 class="mt-1 text-lg font-semibold"><%= photo.title %></h2>
                  <% if current_user&.owner? %>
                    <p class="mt-1 text-xs font-medium uppercase tracking-[0.14em] text-white/75">
                      SHA-256 <%= photo.checksum_status %> · Drive <%= photo.archive_status %>
                    </p>
                  <% end %>
                </div>
                <% if current_user&.owner? %>
                  <% if photo.public? %>
                    <%= button_to "Make private", unpublish_photo_path(photo), method: :patch, class: "relative z-20 rounded-lg border border-white/50 bg-white/10 px-3 py-2 text-xs font-semibold text-white backdrop-blur transition hover:bg-white hover:text-zinc-950" %>
                  <% else %>
                    <%= button_to "Publish", publish_photo_path(photo), method: :patch, class: "relative z-20 rounded-lg border border-white/50 bg-white/10 px-3 py-2 text-xs font-semibold text-white backdrop-blur transition hover:bg-white hover:text-zinc-950" %>
                  <% end %>
                <% end %>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="flex min-h-[440px] items-center justify-center rounded-lg border border-dashed border-zinc-300 bg-white p-8 text-center shadow-sm">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-700">No photos</p>
          <h2 class="mt-3 text-2xl font-semibold text-zinc-950">Nothing published yet.</h2>
        </div>
      </div>
    <% end %>
  </main>
</section>
