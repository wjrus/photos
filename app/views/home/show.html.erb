<% content_for :title, "wjr photos" %>

<section class="min-h-screen bg-stone-50 text-zinc-950">
  <div class="mx-auto grid min-h-screen w-full max-w-7xl grid-cols-1 lg:grid-cols-[340px_1fr]">
    <aside class="flex border-b border-zinc-200 px-6 py-6 lg:min-h-screen lg:flex-col lg:border-b-0 lg:border-r lg:px-8">
      <div class="flex w-full items-center justify-between gap-6 lg:block">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-teal-700">William Rockwood</p>
          <h1 class="mt-3 text-4xl font-semibold tracking-normal text-zinc-950">wjr photos</h1>
          <p class="mt-4 max-w-sm text-sm leading-6 text-zinc-600">
            A private-first photo stream for travels, archives, and the people invited close enough to see the details.
          </p>
        </div>

        <% if signed_in? %>
          <div class="flex items-center gap-3">
            <% if current_user.avatar_url.present? %>
              <%= image_tag current_user.avatar_url, alt: "", class: "size-9 rounded-lg border border-zinc-200" %>
            <% end %>
            <%= button_to "Sign out", sign_out_path, method: :delete, class: "rounded-lg border border-zinc-300 px-4 py-2 text-sm font-medium text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
          </div>
        <% else %>
          <%= button_to "Sign in", "/auth/google_oauth2", method: :post, data: { turbo: false }, class: "rounded-lg border border-zinc-300 px-4 py-2 text-sm font-medium text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
        <% end %>
      </div>

      <div class="mt-auto hidden space-y-4 pt-12 lg:block">
        <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Archive Rule</p>
          <p class="mt-2 text-sm leading-6 text-zinc-700">
            Originals stay intact. Public views use scrubbed derivatives.
          </p>
        </div>
        <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Workers</p>
          <p class="mt-2 text-sm leading-6 text-zinc-700">
            Derivatives, EXIF reads, checksums, and Google Drive mirrors run in background jobs.
          </p>
        </div>
      </div>
    </aside>

    <main class="px-4 py-6 sm:px-6 lg:px-10">
      <div class="mb-5 flex flex-wrap items-center justify-between gap-3">
        <div class="flex rounded-lg border border-zinc-200 bg-white p-1 shadow-sm">
          <button class="rounded-md bg-zinc-950 px-4 py-2 text-sm font-medium text-white">Stream</button>
          <button class="rounded-md px-4 py-2 text-sm font-medium text-zinc-600">Public</button>
          <button class="rounded-md px-4 py-2 text-sm font-medium text-zinc-600">Invited</button>
        </div>
        <button class="rounded-lg bg-teal-700 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-teal-800">
          Upload
        </button>
      </div>

      <div class="grid auto-rows-[220px] grid-cols-2 gap-3 sm:grid-cols-3 xl:grid-cols-4">
        <% [
          ["Summer road", "from future imports", "bg-teal-900", "col-span-2 row-span-2"],
          ["Lakeside", "private", "bg-sky-900", ""],
          ["Late light", "private", "bg-amber-700", ""],
          ["Trail notes", "invited", "bg-emerald-900", ""],
          ["City walk", "private", "bg-rose-900", "col-span-2"],
          ["Archive", "mirrored", "bg-zinc-800", ""],
          ["Map ready", "owner only", "bg-indigo-900", ""]
        ].each do |title, status, color, size| %>
          <article class="<%= [size, color].reject(&:blank?).join(" ") %> group relative overflow-hidden rounded-lg shadow-sm">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(255,255,255,0.32),transparent_28%),linear-gradient(135deg,rgba(255,255,255,0.08),rgba(0,0,0,0.38))]"></div>
            <div class="absolute inset-x-0 bottom-0 p-4 text-white">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] opacity-75"><%= status %></p>
              <h2 class="mt-1 text-lg font-semibold"><%= title %></h2>
            </div>
          </article>
        <% end %>
      </div>
    </main>
  </div>
</section>
