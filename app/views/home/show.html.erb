<% content_for :title, "wjr photos" %>

<section class="min-h-screen bg-stone-50 text-zinc-950">
  <div class="mx-auto grid min-h-screen w-full max-w-7xl grid-cols-1 lg:grid-cols-[340px_1fr]">
    <aside class="flex border-b border-zinc-200 px-6 py-6 lg:min-h-screen lg:flex-col lg:border-b-0 lg:border-r lg:px-8">
      <div class="flex w-full items-center justify-between gap-6 lg:block">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-teal-700">William Rockwood</p>
          <h1 class="mt-3 text-4xl font-semibold tracking-normal text-zinc-950">wjr photos</h1>
          <p class="mt-4 max-w-sm text-sm leading-6 text-zinc-600">
            A private-first photo stream for travels, archives, and the people invited close enough to see the details.
          </p>
        </div>

        <% if signed_in? %>
          <div class="flex items-center gap-3">
            <% if current_user.avatar_url.present? %>
              <%= image_tag current_user.avatar_url, alt: "", class: "size-9 rounded-lg border border-zinc-200" %>
            <% end %>
            <%= button_to "Sign out", sign_out_path, method: :delete, class: "rounded-lg border border-zinc-300 px-4 py-2 text-sm font-medium text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
          </div>
        <% else %>
          <%= button_to "Sign in", "/auth/google_oauth2", method: :post, data: { turbo: false }, class: "rounded-lg border border-zinc-300 px-4 py-2 text-sm font-medium text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
        <% end %>
      </div>

      <div class="mt-auto hidden space-y-4 pt-12 lg:block">
        <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Archive Rule</p>
          <p class="mt-2 text-sm leading-6 text-zinc-700">
            Originals stay intact. Public views use scrubbed derivatives.
          </p>
        </div>
        <div class="rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Workers</p>
          <p class="mt-2 text-sm leading-6 text-zinc-700">
            Derivatives, EXIF reads, checksums, and Google Drive mirrors run in background jobs.
          </p>
        </div>
      </div>
    </aside>

    <main class="px-4 py-6 sm:px-6 lg:px-10">
      <div class="mb-5 flex flex-wrap items-center justify-between gap-3">
        <div class="flex rounded-lg border border-zinc-200 bg-white p-1 shadow-sm">
          <button class="rounded-md bg-zinc-950 px-4 py-2 text-sm font-medium text-white">Stream</button>
          <button class="rounded-md px-4 py-2 text-sm font-medium text-zinc-600">Public</button>
          <button class="rounded-md px-4 py-2 text-sm font-medium text-zinc-600">Invited</button>
        </div>
      </div>

      <% if current_user&.owner? %>
        <%= form_with scope: :photos, url: photos_path, class: "mb-5", data: { controller: "drop-upload", turbo: false } do |form| %>
          <div class="rounded-lg border border-dashed border-zinc-300 bg-white p-5 shadow-sm transition"
               data-action="click->drop-upload#browse dragover->drop-upload#dragover dragleave->drop-upload#dragleave drop->drop-upload#drop">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <p class="text-sm font-semibold text-zinc-950">Import from folder</p>
                <p class="mt-1 text-sm text-zinc-600" data-drop-upload-target="summary">Drop iPhone imports here or choose files.</p>
                <p class="mt-2 text-xs uppercase tracking-[0.16em] text-zinc-400">HEIC JPG PNG MOV MP4 AAE</p>
              </div>
              <div class="flex items-center gap-2">
                <button type="button" class="rounded-lg border border-zinc-300 px-4 py-2 text-sm font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" data-action="drop-upload#browse">Choose</button>
                <%= form.submit "Upload", disabled: true, class: "rounded-lg bg-teal-700 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-teal-800 disabled:cursor-not-allowed disabled:bg-zinc-300", data: { drop_upload_target: "submit" } %>
              </div>
            </div>
            <%= form.file_field :files, multiple: true, accept: ".heic,.heif,.jpg,.jpeg,.png,.mov,.mp4,.aae,image/heic,image/heif,image/jpeg,image/png,video/quicktime,video/mp4", class: "hidden", data: { drop_upload_target: "input", action: "change->drop-upload#choose" } %>
          </div>
        <% end %>
      <% end %>

      <% if @photos.any? %>
        <div class="grid auto-rows-[220px] grid-cols-2 gap-3 sm:grid-cols-3 xl:grid-cols-4">
          <% @photos.each_with_index do |photo, index| %>
            <article class="<%= index.zero? ? "col-span-2 row-span-2" : "" %> group relative overflow-hidden rounded-lg bg-zinc-900 shadow-sm">
              <%= link_to photo_path(photo), class: "absolute inset-0 z-10", aria: { label: "View #{photo.title}" } do %>
                <span class="sr-only">View <%= photo.title %></span>
              <% end %>
              <%= photo_stream_media(photo) %>
              <% if photo.video? %>
                <div class="absolute right-3 top-3 rounded-lg bg-black/55 px-2 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-white backdrop-blur">Video</div>
              <% end %>
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent opacity-90"></div>
              <div class="absolute inset-x-0 bottom-0 p-4 text-white">
                <div class="flex items-center justify-between gap-3">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] opacity-75"><%= photo.visibility %></p>
                    <h2 class="mt-1 text-lg font-semibold"><%= photo.title %></h2>
                    <% if current_user&.owner? %>
                      <p class="mt-1 text-xs font-medium uppercase tracking-[0.14em] text-white/75">
                        SHA-256 <%= photo.checksum_status %> · Drive <%= photo.archive_status %>
                      </p>
                    <% end %>
                  </div>
                  <% if current_user&.owner? %>
                    <% if photo.public? %>
                      <%= button_to "Make private", unpublish_photo_path(photo), method: :patch, class: "relative z-20 rounded-lg border border-white/50 bg-white/10 px-3 py-2 text-xs font-semibold text-white backdrop-blur transition hover:bg-white hover:text-zinc-950" %>
                    <% else %>
                      <%= button_to "Publish", publish_photo_path(photo), method: :patch, class: "relative z-20 rounded-lg border border-white/50 bg-white/10 px-3 py-2 text-xs font-semibold text-white backdrop-blur transition hover:bg-white hover:text-zinc-950" %>
                    <% end %>
                  <% end %>
                </div>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <div class="flex min-h-[440px] items-center justify-center rounded-lg border border-dashed border-zinc-300 bg-white p-8 text-center shadow-sm">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-700">No public photos yet</p>
            <h2 class="mt-3 text-2xl font-semibold text-zinc-950">The stream is waiting for its first original.</h2>
            <p class="mx-auto mt-3 max-w-md text-sm leading-6 text-zinc-600">
              Signed-in owner uploads begin private, then can be published when they are ready for friends and visitors.
            </p>
          </div>
        </div>
      <% end %>
    </main>
  </div>
</section>
