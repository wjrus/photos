<% content_for :title, "Sign in" %>

<section class="min-h-screen bg-stone-50 text-zinc-950">
  <%= render "shared/site_header" %>

  <main class="mx-auto flex min-h-[calc(100vh-5rem)] max-w-lg items-center px-4 py-10 sm:px-6">
    <div class="w-full rounded-lg border border-zinc-200 bg-white p-6 shadow-sm">
      <h1 class="text-2xl font-semibold text-zinc-950">Sign in</h1>

      <%= button_to "Continue with Google",
            "/auth/google_oauth2",
            method: :post,
            data: { turbo: false },
            class: "mt-6 w-full rounded-lg border border-zinc-300 px-4 py-3 text-sm font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>

      <div class="my-6 border-t border-zinc-200"></div>

      <%= form_with url: password_sign_in_path, class: "space-y-4" do |form| %>
        <div>
          <%= form.label :email, "Email", class: "text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500" %>
          <%= form.email_field :email, autocomplete: "username", required: true, class: "mt-2 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15" %>
        </div>
        <div>
          <%= form.label :password, "Password", class: "text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500" %>
          <%= form.password_field :password, autocomplete: "current-password", required: true, class: "mt-2 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15" %>
        </div>
        <label class="flex items-center gap-2 text-sm text-zinc-700">
          <%= check_box_tag :remember_me, "1", false, class: "size-4 rounded border-zinc-300 text-teal-700" %>
          Remember me on this browser
        </label>
        <%= form.submit "Sign in", class: "w-full rounded-lg bg-zinc-950 px-4 py-3 text-sm font-semibold text-white transition hover:bg-teal-800" %>
      <% end %>
    </div>
  </main>
</section>
