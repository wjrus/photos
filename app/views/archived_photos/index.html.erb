<% content_for :title, "Archive" %>

<% content_for :header_actions do %>
  <%= render "photos/bulk_toolbar", albums: @albums, return_to: archived_photos_path, form_id: "archive-photo-bulk-form", archive_context: true %>
<% end %>

<section class="min-h-screen bg-stone-50 text-zinc-950"
         data-controller="bulk-selection"
         data-bulk-selection-form-id-value="archive-photo-bulk-form"
         data-bulk-selection-empty-label-value="Select archived photos, then choose an action.">
  <%= render "shared/site_header" %>

  <main class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="mb-6 border-b border-zinc-200 pb-5">
      <%= link_to "< stream", root_path, class: "text-sm font-semibold text-teal-700 transition hover:text-teal-900" %>
      <h1 class="mt-3 text-3xl font-semibold text-zinc-950">Archive</h1>
      <p class="mt-1 text-sm text-zinc-600"><%= pluralize(@photos.size, "archived item") %></p>
    </div>

    <% if @photos.any? %>
      <%= render "photos/grid",
            photos: @photos,
            return_to: archived_photos_path,
            feature_first: true,
            bulk_form_id: "archive-photo-bulk-form",
            archive_context: true,
            next_cursor: @next_cursor,
            next_page_path: archived_photos_path %>
    <% else %>
      <div class="flex min-h-[440px] items-center justify-center rounded-lg border border-dashed border-zinc-300 bg-white p-8 text-center shadow-sm">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-700">Empty</p>
          <h2 class="mt-3 text-2xl font-semibold text-zinc-950">Nothing archived yet.</h2>
        </div>
      </div>
    <% end %>
  </main>
</section>
