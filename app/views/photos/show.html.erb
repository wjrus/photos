<% content_for :title, @photo.title %>

<section class="relative min-h-screen overflow-hidden bg-zinc-950 text-zinc-950" data-controller="info-panel">
  <div class="min-h-screen w-full">
    <main class="relative flex min-h-screen items-center justify-center bg-zinc-950 p-3 lg:p-6"
          data-controller="stream-navigation"
          data-action="keydown@window->stream-navigation#keydown touchstart->stream-navigation#touchstart touchend->stream-navigation#touchend"
          data-stream-navigation-back-url-value="<%= root_path %>"
          data-stream-navigation-previous-url-value="<%= photo_path(@previous_photo) if @previous_photo %>"
          data-stream-navigation-next-url-value="<%= photo_path(@next_photo) if @next_photo %>">
      <%= link_to root_path,
            class: "absolute left-4 top-4 z-20 rounded-lg border border-white/25 bg-black/55 px-3 py-2 text-sm font-semibold text-white backdrop-blur transition hover:bg-white hover:text-zinc-950",
            aria: { label: "Back to stream" } do %>
        Back
      <% end %>
      <button type="button"
              class="absolute right-4 top-4 z-20 flex h-10 w-10 items-center justify-center rounded-full border border-white/25 bg-black/55 font-serif text-lg font-semibold italic text-white backdrop-blur transition hover:bg-white hover:text-zinc-950"
              aria-label="Show photo information"
              aria-controls="photo-info-panel"
              aria-expanded="false"
              data-info-panel-target="button"
              data-action="info-panel#toggle">
        i
      </button>
      <% if @previous_photo || @next_photo %>
        <nav class="absolute right-4 top-1/2 z-20 flex -translate-y-1/2 flex-col gap-2" aria-label="Stream navigation">
          <% if @previous_photo %>
            <%= link_to "Up",
                  photo_path(@previous_photo),
                  class: "flex h-11 w-14 items-center justify-center rounded-lg border border-white/25 bg-black/55 text-xs font-semibold uppercase text-white backdrop-blur transition hover:bg-white hover:text-zinc-950",
                  aria: { label: "Previous item in stream" },
                  data: { turbo_action: "replace" } %>
          <% end %>
          <% if @next_photo %>
            <%= link_to "Down",
                  photo_path(@next_photo),
                  class: "flex h-11 w-14 items-center justify-center rounded-lg border border-white/25 bg-black/55 text-xs font-semibold uppercase text-white backdrop-blur transition hover:bg-white hover:text-zinc-950",
                  aria: { label: "Next item in stream" },
                  data: { turbo_action: "replace" } %>
          <% end %>
        </nav>
      <% end %>
      <%= photo_detail_media(@photo) %>
    </main>

    <div class="fixed inset-0 z-30 hidden bg-black/35 backdrop-blur-[2px]" data-info-panel-target="backdrop" data-action="click->info-panel#close"></div>

    <aside id="photo-info-panel"
           class="fixed inset-y-0 right-0 z-40 w-full max-w-[390px] translate-x-full overflow-y-auto border-l border-zinc-200 bg-white shadow-2xl transition duration-200 ease-out"
           data-info-panel-target="panel">
      <header class="sticky top-0 z-10 border-b border-zinc-200 bg-white/95 p-5 backdrop-blur">
        <div class="flex items-start gap-3">
          <button type="button"
                  class="flex size-9 shrink-0 items-center justify-center rounded-lg border border-zinc-300 text-xl leading-none text-zinc-700 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white"
                  aria-label="Close photo information"
                  data-action="info-panel#close">
            ×
          </button>

          <div class="min-w-0 flex-1">
            <h1 class="text-xl font-semibold text-zinc-950">Details</h1>
            <p class="mt-1 text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500"><%= @photo.visibility %></p>
          </div>

          <% if current_user&.owner? %>
            <div class="flex shrink-0 items-start gap-2" data-controller="confirm-modal" data-action="keydown@window->confirm-modal#keydown">
              <% if @photo.public? %>
                <%= button_to "Make private", unpublish_photo_path(@photo),
                      method: :patch,
                      params: { return_to: photo_path(@photo) },
                      class: "rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
              <% else %>
                <%= button_to "Publish", publish_photo_path(@photo),
                      method: :patch,
                      params: { return_to: photo_path(@photo) },
                      class: "rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
              <% end %>

              <button type="button"
                      class="rounded-lg border border-rose-200 px-3 py-2 text-xs font-semibold text-rose-800 transition hover:bg-rose-800 hover:text-white"
                      data-action="confirm-modal#open">
                Remove
              </button>

              <div class="fixed inset-0 z-50 hidden items-center justify-center bg-zinc-950/65 p-4 backdrop-blur-sm"
                   role="dialog"
                   aria-modal="true"
                   aria-labelledby="remove-photo-title"
                   data-confirm-modal-target="dialog"
                   data-action="click->confirm-modal#backdrop">
                <div class="w-full max-w-sm rounded-lg border border-rose-200 bg-white p-5 shadow-2xl"
                     data-confirm-modal-target="panel">
                  <h3 id="remove-photo-title" class="text-lg font-semibold text-zinc-950">Remove photo?</h3>
                  <p class="mt-3 text-sm leading-6 text-zinc-600">
                    This deletes the stream item and its stored files. This cannot be undone.
                  </p>
                  <div class="mt-5 grid grid-cols-2 gap-3">
                    <button type="button"
                            class="rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold uppercase text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white"
                            data-action="confirm-modal#close">
                      Cancel
                    </button>
                    <%= button_to "Remove",
                          photo_path(@photo),
                          method: :delete,
                          class: "w-full rounded-lg bg-rose-800 px-3 py-2 text-xs font-semibold uppercase text-white transition hover:bg-rose-950" %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </header>

      <% if privileged_metadata_viewer? %>
        <section class="border-b border-zinc-200 p-5">
          <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Caption</h2>
          <% if @photo.description.present? %>
            <p class="mt-3 whitespace-pre-line text-sm leading-6 text-zinc-700"><%= @photo.description %></p>
          <% else %>
            <p class="mt-3 text-sm text-zinc-500">No caption.</p>
          <% end %>

          <% if current_user&.owner? %>
            <details class="mt-4 group">
              <summary class="inline-flex cursor-pointer list-none rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white">
                <%= @photo.description.present? ? "Edit caption" : "Add caption" %>
              </summary>
              <%= form_with model: @photo, url: caption_photo_path(@photo), method: :patch, class: "mt-4 space-y-3" do |form| %>
                <%= form.label :description, "Caption", class: "sr-only" %>
                <%= form.text_area :description,
                      rows: 5,
                      class: "w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-900 outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15",
                      placeholder: "Write a caption..." %>
                <%= form.submit "Save caption",
                      class: "rounded-lg bg-zinc-950 px-3 py-2 text-xs font-semibold text-white transition hover:bg-teal-800" %>
              <% end %>
            </details>
          <% end %>
        </section>
      <% end %>

      <% if current_user&.owner? %>
        <section class="border-b border-zinc-200 p-5">
          <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Archive</h2>
          <div class="mt-3 flex flex-wrap gap-2 text-xs font-semibold">
            <span class="rounded-lg border border-teal-200 bg-teal-50 px-2 py-1 text-teal-700">
              Drive <%= @photo.archive_status %>
            </span>
            <span class="rounded-lg border border-zinc-200 bg-stone-50 px-2 py-1 text-zinc-700" title="<%= @photo.checksum_sha256 %>">
              SHA-256 <%= @photo.checksum_status %>
            </span>
          </div>

          <dl class="mt-4 space-y-2 text-sm">
            <div class="grid grid-cols-[5rem_1fr] gap-3">
              <dt class="text-zinc-500">Original</dt>
              <dd class="min-w-0 break-words text-right text-zinc-800"><%= @photo.original_filename %></dd>
            </div>
            <div class="grid grid-cols-[5rem_1fr] gap-3">
              <dt class="text-zinc-500">Size</dt>
              <dd class="text-right text-zinc-800"><%= number_to_human_size(@photo.byte_size) %></dd>
            </div>
            <% if @photo.sidecar_count.positive? %>
              <div class="grid grid-cols-[5rem_1fr] gap-3">
                <dt class="text-zinc-500">Sidecars</dt>
                <dd class="text-right text-zinc-800"><%= @photo.sidecar_count %></dd>
              </div>
            <% end %>
          </dl>

          <div class="mt-4 flex flex-wrap gap-2">
            <%= link_to "Download original",
                  photo_original_media_path(@photo),
                  class: "inline-block rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white",
                  download: @photo.original_filename %>
            <% unless @photo.drive_archive_object&.archived? %>
              <%= button_to "Retry Drive", retry_archive_photo_path(@photo), method: :post, class: "rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
            <% end %>
          </div>

          <% if @photo.drive_archive_object&.error.present? %>
            <div class="mt-4 rounded-lg border border-rose-200 bg-rose-50 p-3 text-xs leading-5 text-rose-900">
              <p class="font-semibold uppercase tracking-[0.14em]">Drive error</p>
              <p class="mt-2 break-words"><%= @photo.drive_archive_object.error %></p>
            </div>
          <% end %>
        </section>
      <% end %>

      <% if privileged_metadata_viewer? %>
        <div class="p-5">
          <section>
            <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Info</h2>
            <% metadata = @photo.metadata %>
            <% if metadata.present? %>
              <dl class="mt-3 space-y-2 text-sm">
                <div class="flex justify-between gap-4"><dt class="text-zinc-500">Dimensions</dt><dd class="text-right text-zinc-800"><%= photo_dimensions(metadata) %></dd></div>
                <div class="flex justify-between gap-4"><dt class="text-zinc-500">Captured</dt><dd class="text-right text-zinc-800"><%= metadata.captured_at&.to_fs(:long) || "unknown" %></dd></div>
                <div class="flex justify-between gap-4"><dt class="text-zinc-500">Camera</dt><dd class="text-right text-zinc-800"><%= [metadata.camera_make, metadata.camera_model].compact_blank.join(" ").presence || "unknown" %></dd></div>
                <div class="flex justify-between gap-4"><dt class="text-zinc-500">Lens</dt><dd class="text-right text-zinc-800"><%= metadata.lens_model.presence || "unknown" %></dd></div>
                <div class="flex justify-between gap-4"><dt class="text-zinc-500">Exposure</dt><dd class="text-right text-zinc-800"><%= [metadata.focal_length, metadata.aperture, metadata.exposure_time, ("ISO #{metadata.iso}" if metadata.iso)].compact_blank.join(" · ").presence || "unknown" %></dd></div>
              </dl>

              <% if metadata.location? %>
                <div class="mt-4 overflow-hidden rounded-lg border border-zinc-200 bg-stone-50">
                  <% if photo_map_embed_url(metadata).present? %>
                    <iframe class="h-44 w-full border-0"
                            title="Photo location map"
                            loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade"
                            src="<%= photo_map_embed_url(metadata) %>"></iframe>
                  <% else %>
                    <div class="flex h-44 items-center justify-center bg-stone-50 p-4 text-center text-sm text-zinc-600">
                      Google Maps key missing.
                    </div>
                  <% end %>
                  <div class="p-4">
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Location</p>
                    <p class="mt-2 font-mono text-sm text-zinc-800"><%= metadata.latitude %>, <%= metadata.longitude %></p>
                    <%= link_to "Open map", photo_map_link(metadata), class: "mt-3 inline-block rounded-lg bg-zinc-950 px-3 py-2 text-xs font-semibold text-white", target: "_blank", rel: "noopener" %>
                  </div>
                </div>
              <% else %>
                <div class="mt-4 rounded-lg border border-zinc-200 bg-stone-50 p-4">
                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Location</p>
                  <p class="mt-2 text-sm text-zinc-700">Unavailable</p>
                </div>
              <% end %>
            <% else %>
              <p class="mt-3 text-sm text-zinc-600">Metadata extraction is pending.</p>
            <% end %>
          </section>
        </div>
      <% end %>
    </aside>
  </div>
</section>
