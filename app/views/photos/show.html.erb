<% content_for :title, @photo.title %>
<% content_for :body_class, "photo-detail-page" %>
<% if @photo.public? && @photo.image? %>
  <% content_for :head do %>
  <meta property="og:site_name" content="Photos">
  <meta property="og:type" content="article">
  <meta property="og:title" content="<%= photo_social_title(@photo) %>">
  <meta property="og:description" content="<%= photo_social_description(@photo) %>">
  <meta property="og:url" content="<%= photo_url(@photo, host: request.host_with_port, protocol: request.protocol) %>">
  <meta property="og:image" content="<%= photo_social_image_url(@photo) %>">
  <meta property="og:image:secure_url" content="<%= photo_social_image_url(@photo) %>">
  <meta property="og:image:type" content="<%= photo_social_image_type(@photo) %>">
  <meta property="og:image:alt" content="<%= photo_social_title(@photo) %>">
  <% if @photo.metadata&.width.present? && @photo.metadata&.height.present? %>
    <meta property="og:image:width" content="<%= @photo.metadata.width %>">
    <meta property="og:image:height" content="<%= @photo.metadata.height %>">
  <% end %>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= photo_social_title(@photo) %>">
  <meta name="twitter:description" content="<%= photo_social_description(@photo) %>">
  <meta name="twitter:image" content="<%= photo_social_image_url(@photo) %>">
  <% end %>
<% end %>

<section class="photo-detail-frame relative overflow-hidden bg-zinc-950 text-zinc-950" data-controller="info-panel">
  <%= link_to @return_to,
        class: "ui-tooltip fixed left-4 top-4 z-20 flex size-11 items-center justify-center rounded-lg border border-white/25 bg-black/55 text-white backdrop-blur transition hover:bg-white hover:text-zinc-950",
        aria: { label: "Return to stream" },
        title: "Return to stream",
        data: { tooltip: "Return to stream" } do %>
    <%= app_icon(:chevron_left, classes: "size-7") %>
    <span class="sr-only">Return to stream</span>
  <% end %>

  <div class="photo-detail-frame w-full">
    <%= render "photos/viewer",
          photo: @photo,
          return_to: @return_to,
          previous_photo: @previous_photo,
          next_photo: @next_photo %>

    <%= render "photos/info_panel",
          photo: @photo,
          return_to: @return_to,
          albums: @albums,
          taggable_users: @taggable_users,
          cover_context: @cover_context %>
  </div>
</section>
