<section class="border-b border-zinc-200 p-5">
  <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Caption</h2>
  <% if photo.description.present? %>
    <p class="mt-3 whitespace-pre-line text-sm leading-6 text-zinc-700"><%= photo.description %></p>
  <% else %>
    <p class="mt-3 text-sm text-zinc-500">No caption.</p>
  <% end %>

  <% if current_user&.owner? %>
    <details class="mt-4 group">
      <summary class="inline-flex cursor-pointer list-none rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white">
        <%= photo.description.present? ? "Edit caption" : "Add caption" %>
      </summary>
      <%= form_with model: photo, url: caption_photo_path(photo), method: :patch, class: "mt-4 space-y-3" do |form| %>
        <%= hidden_field_tag :return_to, return_to %>
        <%= form.label :description, "Caption", class: "sr-only" %>
        <%= form.text_area :description,
              rows: 5,
              class: "w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-900 outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15",
              placeholder: "Write a caption..." %>
        <%= form.submit "Save caption",
              class: "rounded-lg bg-zinc-950 px-3 py-2 text-xs font-semibold text-white transition hover:bg-teal-800" %>
      <% end %>
    </details>
  <% end %>
</section>
