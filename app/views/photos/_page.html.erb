<% owner_controls = local_assigns.fetch(:owner_controls, current_user&.owner?) %>
<% album = local_assigns[:album] %>
<% group_by_day = local_assigns.fetch(:group_by_day, true) %>
<% grouped_photos = photos.group_by { |photo| photo_stream_day(photo) } %>

<% if local_assigns[:newer_cursor].present? %>
  <div class="py-6 text-center text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500"
       data-infinite-scroll-target="sentinel"
       data-stream-page-direction="newer"
       data-next-url="<%= path_with_query(next_page_path, newer_cursor: local_assigns[:newer_cursor], stream_page: 1) %>">
    Loading newer...
  </div>
<% end %>

<% if group_by_day %>
  <div class="photo-day-groups">
    <% grouped_photos.each_with_index do |(day, day_photos), group_index| %>
      <%= render "photos/day_group",
            day: day,
            photos: day_photos,
            return_to: return_to,
            feature_first: feature_first && group_index.zero?,
            bulk_form_id: local_assigns[:bulk_form_id],
            owner_controls: owner_controls,
            archive_context: local_assigns[:archive_context],
            album: album %>
    <% end %>
  </div>
<% else %>
  <div class="photo-flat-grid">
    <% photos.each_with_index do |photo, index| %>
      <%= render "photos/card",
            photo: photo,
            return_to: return_to,
            feature: feature_first && index.zero?,
            bulk_form_id: local_assigns[:bulk_form_id],
            owner_controls: owner_controls,
            archive_context: local_assigns[:archive_context],
            album: album %>
    <% end %>
  </div>
<% end %>

<% if next_cursor.present? %>
  <div class="py-6 text-center text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500"
       data-infinite-scroll-target="sentinel"
       data-next-url="<%= path_with_query(next_page_path, cursor: next_cursor, stream_page: 1) %>">
    Loading more...
  </div>
<% end %>
