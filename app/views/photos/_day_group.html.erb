<% day_key = photo_stream_day_key(day) %>

<section id="day-<%= day_key %>"
         class="scroll-mt-24"
         data-bulk-selection-group
         data-stream-date-group-key="<%= day_key %>">
  <header class="mb-3 flex items-center">
    <% if owner_controls %>
      <label class="day-selection-control inline-flex cursor-pointer items-center gap-2 rounded-lg px-2 py-1.5"
             title="Select all photos from <%= photo_stream_day_label(day) %>">
        <input type="checkbox"
               aria-label="Select all photos from <%= photo_stream_day_label(day) %>"
               data-bulk-selection-group-toggle
               data-action="change->bulk-selection#toggleGroup">
        <span class="selection-circle">✓</span>
        <span class="text-sm font-semibold text-zinc-950"><%= photo_stream_day_label(day) %></span>
      </label>
    <% else %>
      <h2 class="text-sm font-semibold text-zinc-950"><%= photo_stream_day_label(day) %></h2>
    <% end %>
  </header>

  <div class="grid auto-rows-[220px] grid-cols-2 gap-3 sm:grid-cols-3 xl:grid-cols-4">
    <% photos.each_with_index do |photo, index| %>
      <%= render "photos/card",
            photo: photo,
            return_to: return_to,
            feature: feature_first && index.zero?,
            bulk_form_id: bulk_form_id,
            owner_controls: owner_controls,
            archive_context: local_assigns[:archive_context],
            album: album %>
    <% end %>
  </div>
</section>
