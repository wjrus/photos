<article class="<%= feature ? "col-span-2 row-span-2" : "" %> group relative overflow-hidden rounded-lg bg-zinc-900 shadow-sm" data-bulk-selection-card>
  <% if owner_controls %>
    <label class="selection-control absolute left-3 top-3 z-20 cursor-pointer"
           title="Select"
           data-action="change->bulk-selection#update">
      <%= check_box_tag "photo_ids[]", photo.id, false, form: bulk_form_id, aria: { label: "Select #{photo.title}" } %>
      <span class="selection-circle">✓</span>
    </label>
  <% end %>

  <% link_data = { photo_return_to: return_to } %>
  <% link_data[:action] = "click->bulk-selection#toggleCard" if owner_controls %>

  <%= link_to photo_path(photo),
        class: "absolute inset-0 z-10",
        aria: { label: "View #{photo.title}" },
        data: link_data do %>
    <span class="sr-only">View <%= photo.title %></span>
  <% end %>
  <%= photo_stream_media(photo) %>
  <% if photo.video? %>
    <div class="absolute right-3 top-3 rounded-lg bg-black/55 px-2 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-white backdrop-blur">Video</div>
  <% end %>
  <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-black/5 to-transparent opacity-80"></div>
</article>
