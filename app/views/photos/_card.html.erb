<article class="<%= feature ? "col-span-2 row-span-2" : "" %> group relative overflow-hidden rounded-lg bg-zinc-900 shadow-sm">
  <% if owner_controls %>
    <label class="selection-control absolute left-3 top-3 z-20 cursor-pointer"
           title="Select"
           data-action="change->bulk-selection#update">
      <%= check_box_tag "photo_ids[]", photo.id, false, form: bulk_form_id, aria: { label: "Select #{photo.title}" } %>
      <span class="selection-circle">✓</span>
    </label>
  <% end %>

  <%= link_to photo_path(photo, return_to: return_to), class: "absolute inset-0 z-10", aria: { label: "View #{photo.title}" } do %>
    <span class="sr-only">View <%= photo.title %></span>
  <% end %>
  <%= photo_stream_media(photo) %>
  <% if photo.video? %>
    <div class="absolute right-3 top-3 rounded-lg bg-black/55 px-2 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-white backdrop-blur">Video</div>
  <% end %>
  <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-black/5 to-transparent opacity-80"></div>
  <div class="absolute inset-x-0 bottom-0 p-4 text-white">
    <div class="flex flex-wrap items-end justify-end gap-2">
      <% if album.present? && owner_controls %>
        <% membership = photo.photo_album_memberships.find { |record| record.photo_album_id == album.id } %>
        <% if membership %>
          <%= button_to "Remove from album",
                photo_album_membership_path(membership),
                method: :delete,
                class: "relative z-20 rounded-lg border border-white/50 bg-white/10 px-3 py-2 text-xs font-semibold text-white backdrop-blur transition hover:bg-white hover:text-zinc-950" %>
        <% end %>
        <%= button_to "Set cover",
              album_cover_path(album, photo),
              method: :patch,
              class: "relative z-20 rounded-lg border border-white/50 bg-white/10 px-3 py-2 text-xs font-semibold text-white backdrop-blur transition hover:bg-white hover:text-zinc-950" %>
      <% end %>

      <% if owner_controls %>
        <% if photo.public? %>
          <%= button_to "Make private",
                unpublish_photo_path(photo),
                method: :patch,
                params: { return_to: return_to },
                class: "relative z-20 rounded-lg border border-white/50 bg-white/10 px-3 py-2 text-xs font-semibold text-white backdrop-blur transition hover:bg-white hover:text-zinc-950" %>
        <% else %>
          <%= button_to "Publish",
                publish_photo_path(photo),
                method: :patch,
                params: { return_to: return_to },
                class: "relative z-20 rounded-lg border border-white/50 bg-white/10 px-3 py-2 text-xs font-semibold text-white backdrop-blur transition hover:bg-white hover:text-zinc-950" %>
        <% end %>
      <% end %>
    </div>
  </div>
</article>
