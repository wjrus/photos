<div class="space-y-7"
     data-stream-page-container
     data-stream-state-target-photo-id-value="<%= local_assigns[:stream_target_photo_id] %>"
     data-controller="<%= [("infinite-scroll" if next_cursor.present? || local_assigns[:newer_cursor].present?), "stream-state", "stream-virtualizer"].compact.join(" ") %>"
     data-action="click->stream-state#save">
  <%= render "photos/page",
        photos: photos,
        return_to: return_to,
        feature_first: feature_first,
        bulk_form_id: local_assigns[:bulk_form_id],
        owner_controls: local_assigns.fetch(:owner_controls, current_user&.owner?),
        archive_context: local_assigns[:archive_context],
        album: local_assigns[:album],
        group_by_day: local_assigns.fetch(:group_by_day, true),
        next_cursor: next_cursor,
        newer_cursor: local_assigns[:newer_cursor],
        next_page_path: next_page_path %>
</div>
