<div class="grid auto-rows-[220px] grid-cols-2 gap-3 sm:grid-cols-3 xl:grid-cols-4"
     data-controller="<%= next_cursor.present? ? "infinite-scroll" : nil %>">
  <%= render "photos/page",
        photos: photos,
        return_to: return_to,
        feature_first: feature_first,
        bulk_form_id: local_assigns[:bulk_form_id],
        owner_controls: local_assigns.fetch(:owner_controls, current_user&.owner?),
        album: local_assigns[:album],
        next_cursor: next_cursor,
        next_page_path: next_page_path %>
</div>
