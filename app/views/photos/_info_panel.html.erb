<div class="fixed inset-0 z-30 hidden bg-black/35 backdrop-blur-[2px]" data-info-panel-target="backdrop" data-action="click->info-panel#close"></div>

<aside id="photo-info-panel"
       class="fixed inset-y-0 right-0 z-40 w-full max-w-[390px] translate-x-full overflow-y-auto border-l border-zinc-200 bg-white shadow-2xl transition duration-200 ease-out"
       data-info-panel-target="panel">
  <header class="sticky top-0 z-10 border-b border-zinc-200 bg-white/95 p-5 backdrop-blur">
    <div class="flex items-start gap-3">
      <button type="button"
              class="flex size-9 shrink-0 items-center justify-center rounded-lg border border-zinc-300 text-xl leading-none text-zinc-700 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white"
              aria-label="Close photo information"
              data-action="info-panel#close">
        ×
      </button>

      <div class="min-w-0 flex-1">
        <h1 class="text-xl font-semibold text-zinc-950">Details</h1>
        <p class="mt-1 text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500"><%= photo.visibility %></p>
      </div>

      <% if current_user&.owner? %>
        <%= render "photos/info_panel_owner_actions", photo: photo, return_to: return_to %>
      <% end %>
    </div>
  </header>

  <% if privileged_metadata_viewer? %>
    <%= render "photos/info_panel_caption", photo: photo, return_to: return_to %>
    <%= render "photos/info_panel_albums", photo: photo %>
  <% end %>

  <% if privileged_metadata_viewer? || photo.tagged_users.any? %>
    <%= render "photos/info_panel_people", photo: photo, taggable_users: taggable_users, return_to: return_to %>
  <% end %>

  <% if current_user&.owner? %>
    <%= render "photos/info_panel_archive", photo: photo, return_to: return_to %>
  <% end %>

  <% if privileged_metadata_viewer? %>
    <%= render "photos/info_panel_metadata", photo: photo %>
  <% end %>
</aside>
