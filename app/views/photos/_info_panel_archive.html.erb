<section class="border-b border-zinc-200 p-5">
  <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Archive</h2>
  <div class="mt-3 flex flex-wrap gap-2 text-xs font-semibold">
    <span class="rounded-lg border border-teal-200 bg-teal-50 px-2 py-1 text-teal-700">
      Drive <%= photo.archive_status %>
    </span>
    <span class="rounded-lg border border-zinc-200 bg-stone-50 px-2 py-1 text-zinc-700" title="<%= photo.checksum_sha256 %>">
      SHA-256 <%= photo.checksum_status %>
    </span>
  </div>

  <dl class="mt-4 space-y-2 text-sm">
    <div class="grid grid-cols-[5rem_1fr] gap-3">
      <dt class="text-zinc-500">Original</dt>
      <dd class="min-w-0 break-words text-right text-zinc-800"><%= photo.original_filename %></dd>
    </div>
    <div class="grid grid-cols-[5rem_1fr] gap-3">
      <dt class="text-zinc-500">Size</dt>
      <dd class="text-right text-zinc-800"><%= number_to_human_size(photo.byte_size) %></dd>
    </div>
    <% if photo.sidecar_count.positive? %>
      <div class="grid grid-cols-[5rem_1fr] gap-3">
        <dt class="text-zinc-500">Sidecars</dt>
        <dd class="text-right text-zinc-800"><%= photo.sidecar_count %></dd>
      </div>
    <% end %>
  </dl>

  <div class="mt-4 flex flex-wrap gap-2">
    <%= link_to "Download original",
          photo_original_media_path(photo),
          class: "inline-block rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white",
          download: photo.original_filename %>
    <% unless photo.drive_archive_object&.archived? %>
      <%= button_to "Retry Drive", retry_archive_photo_path(photo), method: :post, params: { return_to: return_to }, class: "rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
    <% end %>
  </div>

  <% if photo.drive_archive_object&.error.present? %>
    <div class="mt-4 rounded-lg border border-rose-200 bg-rose-50 p-3 text-xs leading-5 text-rose-900">
      <p class="font-semibold uppercase tracking-[0.14em]">Drive error</p>
      <p class="mt-2 break-words"><%= photo.drive_archive_object.error %></p>
    </div>
  <% end %>
</section>
