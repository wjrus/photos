<%= form_with url: photo_bulk_actions_path,
      method: :post,
      html: {
        id: form_id,
        class: "sticky top-[73px] z-30 mb-4 rounded-lg border border-zinc-800 bg-zinc-950/95 p-2 text-white shadow-lg backdrop-blur",
        data: { action: "submit->bulk-selection#guard" }
      } do %>
  <%= hidden_field_tag :return_to, return_to %>
  <div class="flex min-h-12 flex-wrap items-center justify-between gap-2">
    <p class="px-3 text-sm font-semibold" aria-live="polite" data-bulk-selection-target="count">
      Select photos, then choose an action.
    </p>

    <div class="flex flex-wrap items-center gap-1">
      <button type="button"
              disabled
              title="Deselect all"
              aria-label="Deselect all"
              data-bulk-selection-target="action"
              data-action="bulk-selection#clear"
              class="flex size-10 items-center justify-center rounded-lg text-white transition hover:bg-white/10 disabled:opacity-40">
        <%= app_icon(:x) %>
        <span class="sr-only">Deselect all</span>
      </button>
      <button type="submit"
              name="bulk_action"
              value="publish"
              disabled
              title="Publish selected photos"
              aria-label="Publish selected photos"
              data-bulk-selection-target="action"
              class="flex size-10 items-center justify-center rounded-lg text-white transition hover:bg-white/10 disabled:opacity-40">
        <%= app_icon(:globe) %>
        <span class="sr-only">Publish selected photos</span>
      </button>
      <button type="submit"
              name="bulk_action"
              value="unpublish"
              disabled
              title="Make selected photos private"
              aria-label="Make selected photos private"
              data-bulk-selection-target="action"
              class="flex size-10 items-center justify-center rounded-lg text-white transition hover:bg-white/10 disabled:opacity-40">
        <%= app_icon(:lock) %>
        <span class="sr-only">Make selected photos private</span>
      </button>

      <details class="relative" data-bulk-selection-target="action">
        <summary class="flex size-10 cursor-pointer list-none items-center justify-center rounded-lg text-white transition hover:bg-white/10"
                 title="Add selected photos to an album"
                 aria-label="Add selected photos to an album"
                 data-action="click->bulk-selection#guard">
          <%= app_icon(:image_plus) %>
          <span class="sr-only">Add selected photos to an album</span>
        </summary>
        <div class="absolute right-0 z-40 mt-2 w-[min(92vw,340px)] rounded-lg border border-zinc-200 bg-white p-4 text-zinc-950 shadow-2xl">
          <div class="space-y-3">
            <% if albums.any? %>
              <div>
                <label for="album_id" class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">Existing</label>
                <select id="album_id" name="album_id" class="mt-2 w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15">
                  <option value="">Choose album</option>
                  <% albums.each do |album| %>
                    <option value="<%= album.id %>"><%= album.title %></option>
                  <% end %>
                </select>
              </div>
            <% end %>

            <div>
              <label for="new_album_title" class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">New</label>
              <input id="new_album_title"
                     name="new_album_title"
                     type="text"
                     class="mt-2 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15"
                     placeholder="Album name">
            </div>

            <button type="submit"
                    name="bulk_action"
                    value="add_to_album"
                    disabled
                    title="Add selected photos"
                    aria-label="Add selected photos"
                    data-bulk-selection-target="action"
                    class="w-full rounded-lg bg-zinc-950 px-3 py-2 text-sm font-semibold text-white transition hover:bg-teal-800 disabled:cursor-not-allowed disabled:bg-zinc-300">
              Add selected
            </button>
          </div>
        </div>
      </details>

      <div data-controller="confirm-modal" data-action="keydown@window->confirm-modal#keydown">
        <button type="button"
                disabled
                title="Remove selected photos"
                aria-label="Remove selected photos"
                class="flex size-10 items-center justify-center rounded-lg text-white transition hover:bg-rose-800 disabled:opacity-40"
                data-bulk-selection-target="action"
                data-action="confirm-modal#open">
          <%= app_icon(:trash) %>
          <span class="sr-only">Remove selected photos</span>
        </button>

        <div class="fixed inset-0 z-50 hidden items-center justify-center bg-zinc-950/65 p-4 backdrop-blur-sm"
             role="dialog"
             aria-modal="true"
             aria-labelledby="remove-selected-title"
             data-confirm-modal-target="dialog"
             data-action="click->confirm-modal#backdrop">
          <div class="w-full max-w-sm rounded-lg border border-rose-200 bg-white p-5 text-zinc-950 shadow-2xl"
               data-confirm-modal-target="panel">
            <h3 id="remove-selected-title" class="text-lg font-semibold text-zinc-950">Remove selected photos?</h3>
            <p class="mt-3 text-sm leading-6 text-zinc-600">
              This deletes the selected stream items and their stored files. This cannot be undone.
            </p>
            <div class="mt-5 grid grid-cols-2 gap-3">
              <button type="button"
                      class="rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold uppercase text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white"
                      data-action="confirm-modal#close">
                Cancel
              </button>
              <button type="submit"
                      name="bulk_action"
                      value="delete"
                      class="rounded-lg bg-rose-800 px-3 py-2 text-xs font-semibold uppercase text-white transition hover:bg-rose-950">
                Remove
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
