<%= form_with url: photo_bulk_actions_path, method: :post, html: { id: form_id, class: "sticky top-[73px] z-30 mb-4 rounded-lg border border-zinc-200 bg-white/95 p-3 shadow-sm backdrop-blur" } do %>
  <%= hidden_field_tag :return_to, return_to %>
  <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-700">Selection</p>
      <p class="mt-1 text-sm text-zinc-600">Check photos, then choose an action.</p>
    </div>

    <div class="flex flex-wrap items-center gap-2">
      <button type="submit"
              name="bulk_action"
              value="publish"
              class="rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white">
        Publish
      </button>
      <button type="submit"
              name="bulk_action"
              value="unpublish"
              class="rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white">
        Make private
      </button>

      <details class="relative">
        <summary class="cursor-pointer list-none rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white">
          Add to album
        </summary>
        <div class="absolute right-0 z-40 mt-2 w-[min(92vw,340px)] rounded-lg border border-zinc-200 bg-white p-4 shadow-2xl">
          <div class="space-y-3">
            <% if albums.any? %>
              <div>
                <label for="album_id" class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">Existing</label>
                <select id="album_id" name="album_id" class="mt-2 w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15">
                  <option value="">Choose album</option>
                  <% albums.each do |album| %>
                    <option value="<%= album.id %>"><%= album.title %></option>
                  <% end %>
                </select>
              </div>
            <% end %>

            <div>
              <label for="new_album_title" class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">New</label>
              <input id="new_album_title"
                     name="new_album_title"
                     type="text"
                     class="mt-2 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15"
                     placeholder="Album name">
            </div>

            <button type="submit"
                    name="bulk_action"
                    value="add_to_album"
                    class="w-full rounded-lg bg-zinc-950 px-3 py-2 text-sm font-semibold text-white transition hover:bg-teal-800">
              Add selected
            </button>
          </div>
        </div>
      </details>

      <div data-controller="confirm-modal" data-action="keydown@window->confirm-modal#keydown">
        <button type="button"
                class="rounded-lg border border-rose-200 px-3 py-2 text-xs font-semibold text-rose-800 transition hover:bg-rose-800 hover:text-white"
                data-action="confirm-modal#open">
          Remove
        </button>

        <div class="fixed inset-0 z-50 hidden items-center justify-center bg-zinc-950/65 p-4 backdrop-blur-sm"
             role="dialog"
             aria-modal="true"
             aria-labelledby="remove-selected-title"
             data-confirm-modal-target="dialog"
             data-action="click->confirm-modal#backdrop">
          <div class="w-full max-w-sm rounded-lg border border-rose-200 bg-white p-5 shadow-2xl"
               data-confirm-modal-target="panel">
            <h3 id="remove-selected-title" class="text-lg font-semibold text-zinc-950">Remove selected photos?</h3>
            <p class="mt-3 text-sm leading-6 text-zinc-600">
              This deletes the selected stream items and their stored files. This cannot be undone.
            </p>
            <div class="mt-5 grid grid-cols-2 gap-3">
              <button type="button"
                      class="rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold uppercase text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white"
                      data-action="confirm-modal#close">
                Cancel
              </button>
              <button type="submit"
                      name="bulk_action"
                      value="delete"
                      class="rounded-lg bg-rose-800 px-3 py-2 text-xs font-semibold uppercase text-white transition hover:bg-rose-950">
                Remove
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
<% end %>
