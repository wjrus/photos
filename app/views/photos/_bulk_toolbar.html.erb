<%= form_with url: photo_bulk_actions_path,
      method: :post,
      html: {
        id: form_id,
        class: "hidden items-center gap-2",
        data: { bulk_selection_target: "bar", action: "submit->bulk-selection#guard" }
      } do %>
  <%= hidden_field_tag :return_to, return_to %>
  <%= hidden_field_tag :context_album_id, local_assigns[:album].id if local_assigns[:album].present? %>
  <p class="hidden rounded-lg bg-zinc-950 px-3 py-2 text-sm font-semibold text-white shadow-sm sm:block" aria-live="polite" data-bulk-selection-target="count">
    Select photos, then choose an action.
  </p>

  <div class="flex items-center gap-1 rounded-lg border border-zinc-200 bg-white p-1 shadow-sm">
      <%= bulk_action_button(icon: :x, label: "Deselect all", type: "button", action: "bulk-selection#clear") %>
      <% if local_assigns[:archive_context] %>
        <%= bulk_action_button(icon: :rotate_ccw, label: "Restore selected photos to stream", value: "restore") %>
      <% else %>
        <%= bulk_action_button(icon: :globe, label: "Publish selected", value: "publish") %>
        <%= bulk_action_button(icon: :lock, label: "Unpublish selected", value: "unpublish") %>
        <%= bulk_action_button(icon: :archive, label: "Move selected photos to archive", value: "archive") %>
        <% if local_assigns[:album].present? %>
          <%= bulk_action_button(icon: :image, label: "Set selected photo as album cover", value: "set_album_cover") %>
          <%= render "shared/bulk_confirm_modal",
                button_icon: :image_minus,
                button_label: "Remove selected photos from this album",
                title_id: "remove-selected-from-album-title",
                title: "Remove selected photos from this album?",
                body: "This removes the selected items from #{local_assigns[:album].title}. The photos stay in your library.",
                value: "remove_from_album",
                confirm_label: "Remove" %>
        <% end %>
        <%= render "shared/bulk_confirm_modal",
              button_icon: :shield,
              button_label: "Lock selected",
              title_id: "restrict-selected-title",
              title: "Lock selected?",
              body: "This hides the selected items from the normal stream, albums, search, locations, and map. They will only be visible after unlocking Private.",
              value: "restrict",
              confirm_label: "Move" %>
      <% end %>

      <% unless local_assigns[:archive_context] %>
        <details class="relative" data-bulk-selection-target="action">
          <summary class="ui-tooltip flex size-10 cursor-pointer list-none items-center justify-center rounded-lg text-zinc-800 transition hover:bg-zinc-100"
                   title="Add selected photos to an album"
                   aria-label="Add selected photos to an album"
                   data-tooltip="Add to album"
                   data-action="click->bulk-selection#guard">
            <%= app_icon(:image_plus) %>
            <span class="sr-only">Add selected photos to an album</span>
          </summary>
          <div class="absolute right-0 z-40 mt-2 w-[min(92vw,340px)] rounded-lg border border-zinc-200 bg-white p-4 text-zinc-950 shadow-2xl">
            <div class="space-y-3">
              <% if albums.any? %>
                <div>
                  <label for="album_id" class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">Existing</label>
                  <select id="album_id" name="album_id" class="mt-2 w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15">
                    <option value="">Choose album</option>
                    <% albums.each do |album| %>
                      <option value="<%= album.id %>"><%= album.title %></option>
                    <% end %>
                  </select>
                </div>
              <% end %>

              <div>
                <label for="new_album_title" class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">New</label>
                <input id="new_album_title"
                       name="new_album_title"
                       type="text"
                       class="mt-2 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15"
                       placeholder="Album name">
              </div>

              <button type="submit"
                      name="bulk_action"
                      value="add_to_album"
                      disabled
                      title="Add selected photos"
                      aria-label="Add selected photos"
                      data-bulk-selection-target="action"
                      class="w-full rounded-lg bg-zinc-950 px-3 py-2 text-sm font-semibold text-white transition hover:bg-teal-800 disabled:cursor-not-allowed disabled:bg-zinc-300">
                Add selected
              </button>
            </div>
          </div>
        </details>
      <% end %>

      <%= render "shared/bulk_confirm_modal",
            button_label: "Remove selected photos",
            title_id: "remove-selected-title",
            title: "Remove selected photos?",
            body: "This deletes the selected stream items and their stored files. This cannot be undone.",
            value: "delete",
            confirm_label: "Remove" %>
  </div>
<% end %>
