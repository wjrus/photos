<section class="border-b border-zinc-200 p-5">
  <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">People</h2>
  <% if photo.tagged_users.any? %>
    <div class="mt-3 flex flex-wrap gap-2">
      <% photo.photo_people_tags.includes(:user).each do |tag| %>
        <div class="group relative">
          <%= user_avatar(tag.user, classes: "size-10 rounded-lg border border-zinc-200 object-cover") %>
          <span class="pointer-events-none absolute left-0 top-full z-20 mt-2 hidden w-max max-w-48 rounded-md bg-zinc-950 px-2 py-1 text-xs font-semibold text-white shadow-lg group-hover:block group-focus-within:block">
            <%= tag.user.display_name %>
          </span>
          <% if current_user&.owner? %>
            <%= button_to "×",
                  photo_people_tag_path(tag, return_to: return_to),
                  method: :delete,
                  aria: { label: "Remove #{tag.user.display_name} tag" },
                  class: "absolute -right-2 -top-2 flex size-5 items-center justify-center rounded-full bg-zinc-950 text-xs leading-none text-white shadow-sm transition hover:bg-rose-800" %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="mt-3 text-sm text-zinc-500">No people tagged.</p>
  <% end %>

  <% if current_user&.owner? && taggable_users.present? %>
    <%= form_with url: photo_photo_people_tags_path(photo), class: "mt-4 flex gap-2" do |form| %>
      <%= hidden_field_tag :return_to, return_to %>
      <%= select_tag :user_id,
            options_from_collection_for_select(taggable_users, :id, :display_name),
            prompt: "Tag someone",
            class: "min-w-0 flex-1 rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15" %>
      <%= form.submit "Tag", class: "rounded-lg bg-zinc-950 px-3 py-2 text-xs font-semibold text-white transition hover:bg-teal-800" %>
    <% end %>
  <% end %>
</section>
