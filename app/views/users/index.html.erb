<% content_for :title, "Users" %>

<section class="min-h-screen bg-stone-50 text-zinc-950">
  <%= render "shared/site_header" %>

  <main class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-4 border-b border-zinc-200 pb-5 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-700">Owner</p>
        <h1 class="mt-2 text-3xl font-semibold text-zinc-950">Users and sharing</h1>
        <p class="mt-2 text-sm text-zinc-600">Invite viewers, send account links, and see private album access at a glance.</p>
      </div>
      <div class="text-sm text-zinc-600">
        <span class="font-semibold text-zinc-950"><%= number_with_delimiter(@user_count) %></span>
        <%= "user".pluralize(@user_count) %>
      </div>
    </div>

    <section class="mt-6 rounded-lg border border-zinc-200 bg-white p-5 shadow-sm">
      <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-zinc-500">Invite</h2>
      <%= form_with model: @invite, url: users_path, class: "mt-4 grid gap-3 md:grid-cols-[1fr_1fr_1.4fr_auto]" do |form| %>
        <div>
          <%= form.label :first_name, "First name", class: "sr-only" %>
          <%= form.text_field :first_name, placeholder: "First name", autocomplete: "given-name", class: "w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15" %>
        </div>
        <div>
          <%= form.label :last_name, "Last name", class: "sr-only" %>
          <%= form.text_field :last_name, placeholder: "Last name", autocomplete: "family-name", class: "w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15" %>
        </div>
        <div>
          <%= form.label :email, "Email address", class: "sr-only" %>
          <%= form.email_field :email, placeholder: "email@example.com", autocomplete: "email", required: true, class: "w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15" %>
        </div>
        <%= form.submit "Invite", class: "rounded-lg bg-zinc-950 px-4 py-2 text-sm font-semibold text-white transition hover:bg-teal-800" %>
      <% end %>
    </section>

    <section class="mt-6 overflow-x-auto rounded-lg border border-zinc-200 bg-white shadow-sm">
      <table class="min-w-[62rem] w-full text-left text-sm">
        <thead class="border-b border-zinc-200 bg-stone-50 text-xs uppercase tracking-[0.14em] text-zinc-500">
          <tr>
            <th class="px-4 py-3">User</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Shared albums</th>
            <th class="px-4 py-3">Account links</th>
            <th class="px-4 py-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-100">
          <% @users.each do |user| %>
            <% album_shares = user.photo_album_shares.sort_by { |share| [share.photo_album.title.downcase, share.photo_album.id] } %>
            <tr>
              <td class="px-4 py-4 align-top">
                <div class="flex items-center gap-3">
                  <%= user_avatar(user) %>
                  <div class="min-w-0">
                    <p class="font-semibold text-zinc-950"><%= user.display_name %></p>
                    <p class="truncate text-zinc-500"><%= user.email %></p>
                  </div>
                </div>
              </td>
              <td class="px-4 py-4 align-top text-zinc-700">
                <span class="rounded-lg border px-2 py-1 text-xs font-semibold <%= user.owner? ? "border-zinc-300 bg-zinc-950 text-white" : user.invite_accepted? ? "border-teal-200 bg-teal-50 text-teal-900" : "border-amber-200 bg-amber-50 text-amber-900" %>">
                  <%= user.owner? ? "owner" : (user.invite_accepted? ? "active" : "invited") %>
                </span>
                <% if user.last_signed_in_at.present? %>
                  <p class="mt-2 text-xs text-zinc-500">Signed in <%= time_ago_in_words(user.last_signed_in_at) %> ago</p>
                <% end %>
              </td>
              <td class="px-4 py-4 align-top">
                <% if album_shares.any? %>
                  <div class="flex max-w-md flex-wrap gap-2">
                    <% album_shares.first(8).each do |share| %>
                      <% album = share.photo_album %>
                      <div class="inline-flex overflow-hidden rounded-lg border border-zinc-200 bg-stone-50 text-xs font-semibold text-zinc-700">
                        <%= link_to album.title,
                              album_path(album),
                              class: "px-2 py-1 transition hover:bg-zinc-950 hover:text-white" %>
                        <div data-controller="confirm-modal" data-action="keydown@window->confirm-modal#keydown">
                          <button type="button"
                                  class="flex h-full items-center border-l border-zinc-200 px-2 text-zinc-500 transition hover:bg-rose-800 hover:text-white"
                                  aria-label="Stop sharing <%= album.title %> with <%= user.display_name %>"
                                  title="Stop sharing <%= album.title %> with <%= user.display_name %>"
                                  data-action="confirm-modal#open">
                            <%= app_icon(:circle_x, classes: "size-3.5") %>
                          </button>

                          <div class="fixed inset-0 z-50 hidden items-center justify-center bg-zinc-950/65 p-4 text-left backdrop-blur-sm"
                               role="dialog"
                               aria-modal="true"
                               aria-labelledby="remove-share-<%= share.id %>-title"
                               data-confirm-modal-target="dialog"
                               data-action="click->confirm-modal#backdrop">
                            <div class="w-full max-w-sm rounded-lg border border-rose-200 bg-white p-5 shadow-2xl"
                                 data-confirm-modal-target="panel">
                              <h3 id="remove-share-<%= share.id %>-title" class="text-lg font-semibold text-zinc-950">Stop sharing album?</h3>
                              <p class="mt-3 text-sm leading-6 text-zinc-600">
                                This removes <%= user.display_name %>'s access to <span class="font-semibold text-zinc-950"><%= album.title %></span>.
                              </p>
                              <div class="mt-5 grid grid-cols-2 gap-3">
                                <button type="button"
                                        class="rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold uppercase text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white"
                                        data-action="confirm-modal#close">
                                  Cancel
                                </button>
                                <%= button_to "Remove",
                                      album_share_path(share),
                                      method: :delete,
                                      params: { return_to: users_path(page: @page) },
                                      class: "w-full rounded-lg bg-rose-800 px-3 py-2 text-xs font-semibold uppercase text-white transition hover:bg-rose-950" %>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    <% end %>
                    <% if album_shares.size > 8 %>
                      <span class="rounded-lg border border-zinc-200 px-2 py-1 text-xs font-semibold text-zinc-500">+<%= album_shares.size - 8 %></span>
                    <% end %>
                  </div>
                <% else %>
                  <span class="text-zinc-500">No shared albums.</span>
                <% end %>
              </td>
              <td class="px-4 py-4 align-top">
                <div class="space-y-2">
                  <% if user.invited_pending? %>
                    <% invite_url = invitation_url(user.invitation_url_token) %>
                    <input type="text"
                           readonly
                           value="<%= invite_url %>"
                           aria-label="Invitation link for <%= user.display_name %>"
                           data-controller="select-text"
                           data-action="focus->select-text#select click->select-text#select"
                           class="w-full rounded-lg border border-zinc-300 bg-stone-50 px-3 py-2 text-xs text-zinc-700">
                  <% end %>
                  <% if user.password_reset_valid? %>
                    <span class="text-xs text-zinc-500">Reset sent <%= time_ago_in_words(user.password_reset_sent_at) %> ago</span>
                  <% else %>
                    <span class="text-xs text-zinc-500">No active reset link.</span>
                  <% end %>
                </div>
              </td>
              <td class="px-4 py-4 text-right align-top">
                <div class="flex flex-col items-end gap-2">
                  <% if user.invited_pending? %>
                    <%= button_to "Send invite",
                          send_invitation_user_path(user, page: @page),
                          method: :post,
                          class: "rounded-lg border border-zinc-300 bg-white px-3 py-2 text-xs font-semibold uppercase text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
                  <% end %>
                  <%= button_to "Send reset",
                        send_password_reset_user_path(user, page: @page),
                        method: :post,
                        class: "rounded-lg border border-zinc-300 bg-white px-3 py-2 text-xs font-semibold uppercase text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>

                  <% if user.owner? || user == current_user %>
                    <span class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-600">Protected</span>
                  <% else %>
                    <div class="inline-block" data-controller="confirm-modal" data-action="keydown@window->confirm-modal#keydown">
                      <button type="button"
                              class="rounded-lg border border-rose-200 px-3 py-2 text-xs font-semibold uppercase text-rose-800 transition hover:bg-rose-800 hover:text-white"
                              data-action="confirm-modal#open">
                        Remove
                      </button>

                      <div class="fixed inset-0 z-50 hidden items-center justify-center bg-zinc-950/65 p-4 text-left backdrop-blur-sm"
                           role="dialog"
                           aria-modal="true"
                           aria-labelledby="remove-user-<%= user.id %>-title"
                           data-confirm-modal-target="dialog"
                           data-action="click->confirm-modal#backdrop">
                        <div class="w-full max-w-sm rounded-lg border border-rose-200 bg-white p-5 shadow-2xl"
                             data-confirm-modal-target="panel">
                          <h3 id="remove-user-<%= user.id %>-title" class="text-lg font-semibold text-zinc-950">Remove user?</h3>
                          <p class="mt-3 text-sm leading-6 text-zinc-600">
                            This removes <%= user.display_name %> and their access to private photos. Tags for this user will also be removed.
                          </p>
                          <div class="mt-5 grid grid-cols-2 gap-3">
                            <button type="button"
                                    class="rounded-lg border border-zinc-300 px-3 py-2 text-xs font-semibold uppercase text-zinc-800 transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white"
                                    data-action="confirm-modal#close">
                              Cancel
                            </button>
                            <%= button_to "Remove",
                                  user_path(user),
                                  method: :delete,
                                  class: "w-full rounded-lg bg-rose-800 px-3 py-2 text-xs font-semibold uppercase text-white transition hover:bg-rose-950" %>
                          </div>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </section>

    <% if @page_count > 1 %>
      <nav class="mt-5 flex items-center justify-between gap-3" aria-label="Users pagination">
        <%= link_to "Previous",
              users_path(page: @page - 1),
              class: "rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-800 shadow-sm transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white #{'pointer-events-none opacity-40' if @page <= 1}",
              aria: { disabled: @page <= 1 } %>
        <p class="text-sm text-zinc-600">Page <%= @page %> of <%= @page_count %></p>
        <%= link_to "Next",
              users_path(page: @page + 1),
              class: "rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-800 shadow-sm transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white #{'pointer-events-none opacity-40' if @page >= @page_count}",
              aria: { disabled: @page >= @page_count } %>
      </nav>
    <% end %>
  </main>
</section>
