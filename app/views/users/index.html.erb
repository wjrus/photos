<% content_for :title, "Users" %>

<section class="min-h-screen bg-stone-50 text-zinc-950">
  <%= render "shared/site_header" %>

  <main class="mx-auto max-w-5xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-4 border-b border-zinc-200 pb-5 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-700">Users</p>
        <h1 class="mt-2 text-3xl font-semibold text-zinc-950">Users</h1>
      </div>
    </div>

    <section class="mt-6 rounded-lg border border-zinc-200 bg-white p-5 shadow-sm">
      <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-zinc-500">Invite</h2>
      <%= form_with model: @invite, url: users_path, class: "mt-4 grid gap-3 md:grid-cols-[1fr_1fr_1.4fr_auto]" do |form| %>
        <%= form.text_field :first_name, placeholder: "First name", class: "rounded-lg border border-zinc-300 px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15" %>
        <%= form.text_field :last_name, placeholder: "Last name", class: "rounded-lg border border-zinc-300 px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15" %>
        <%= form.email_field :email, placeholder: "email@example.com", required: true, class: "rounded-lg border border-zinc-300 px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15" %>
        <%= form.submit "Invite", class: "rounded-lg bg-zinc-950 px-4 py-2 text-sm font-semibold text-white transition hover:bg-teal-800" %>
      <% end %>
    </section>

    <section class="mt-6 overflow-hidden rounded-lg border border-zinc-200 bg-white shadow-sm">
      <table class="w-full text-left text-sm">
        <thead class="border-b border-zinc-200 bg-stone-50 text-xs uppercase tracking-[0.14em] text-zinc-500">
          <tr>
            <th class="px-4 py-3">User</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Invite link</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-100">
          <% @users.each do |user| %>
            <tr>
              <td class="px-4 py-3">
                <div class="flex items-center gap-3">
                  <%= user_avatar(user) %>
                  <div>
                    <p class="font-semibold text-zinc-950"><%= user.display_name %></p>
                    <p class="text-zinc-500"><%= user.email %></p>
                  </div>
                </div>
              </td>
              <td class="px-4 py-3 text-zinc-700">
                <%= user.owner? ? "owner" : (user.invite_accepted? ? "active" : "invited") %>
              </td>
              <td class="px-4 py-3">
                <% if user.invited_pending? %>
                  <% invite_url = invitation_url(user.invitation_url_token) %>
                  <input type="text"
                         readonly
                         value="<%= invite_url %>"
                         onclick="this.select()"
                         aria-label="Invitation link for <%= user.display_name %>"
                         class="w-full rounded-lg border border-zinc-300 bg-stone-50 px-3 py-2 text-xs text-zinc-700">
                <% else %>
                  <span class="text-zinc-400">-</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </section>
  </main>
</section>
