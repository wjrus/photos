<% content_for :title, "Private" %>

<section class="min-h-screen bg-stone-50 text-zinc-950">
  <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <% if @photos %>
      <div class="mb-6 flex items-center justify-between gap-4 border-b border-zinc-200 pb-5">
        <div>
          <%= link_to "Back to stream", root_path, class: "text-xs font-semibold uppercase tracking-[0.18em] text-teal-700 transition hover:text-teal-900" %>
          <h1 class="mt-3 text-3xl font-semibold text-zinc-950">Private</h1>
          <p class="mt-1 text-sm text-zinc-600"><%= pluralize(@photos.size, "photo") %></p>
        </div>
        <%= button_to "Lock",
              lock_restricted_photos_path,
              method: :delete,
              class: "rounded-lg border border-zinc-300 bg-white px-4 py-2 text-sm font-semibold text-zinc-800 shadow-sm transition hover:border-zinc-950 hover:bg-zinc-950 hover:text-white" %>
      </div>

      <% if @photos.any? %>
        <%= render "photos/grid",
              photos: @photos,
              return_to: restricted_photos_path,
              feature_first: true,
              owner_controls: false,
              next_cursor: nil,
              next_page_path: restricted_photos_path %>
      <% else %>
        <div class="flex min-h-[340px] items-center justify-center rounded-lg border border-dashed border-zinc-300 bg-white p-8 text-center shadow-sm">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-teal-700">Empty</p>
            <h2 class="mt-3 text-2xl font-semibold text-zinc-950">Nothing here.</h2>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="mx-auto mt-16 max-w-sm rounded-lg border border-zinc-200 bg-white p-5 shadow-sm">
        <h1 class="text-xl font-semibold text-zinc-950">Private</h1>
        <%= form_with url: unlock_restricted_photos_path, method: :post, class: "mt-5 space-y-4" do |form| %>
          <div>
            <%= form.label :password, "Password", class: "text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500" %>
            <%= form.password_field :password,
                  class: "mt-2 w-full rounded-lg border border-zinc-300 px-3 py-2 text-sm outline-none transition focus:border-teal-700 focus:ring-2 focus:ring-teal-700/15",
                  autocomplete: "current-password",
                  autofocus: true %>
          </div>
          <%= form.submit "Open",
                class: "w-full rounded-lg bg-zinc-950 px-3 py-2 text-sm font-semibold text-white transition hover:bg-teal-800" %>
        <% end %>
      </div>
    <% end %>
  </main>
</section>
