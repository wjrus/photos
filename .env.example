GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_ARCHIVE_FOLDER_ID=
GOOGLE_MAPS_EMBED_API_KEY=
GOOGLE_MAPS_GEOCODING_API_KEY=
GOOGLE_MAPS_MAP_ID=
PHOTOS_OWNER_EMAIL=
PHOTOS_TRUSTED_VIEWER_EMAILS=

MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.example.com
MAILGUN_FROM=photos@example.invalid
MAILGUN_FROM_NAME=Photos
# MAILGUN_REPLY_TO=photos@example.invalid
# MAILGUN_API_BASE=https://api.mailgun.net

# Runtime repository controls, such as original file auto-heal, live in the app
# settings table and are managed from Repository Status.

# Photo analysis is opt-in by provider from Repository Status. Local OpenCLIP
# and YOLO processors should run in a Docker sidecar. OpenAI stays disabled
# until an owner explicitly enables it and configures a server-side key.
ANALYSIS_LOCAL_CONTAINER_URL=http://analysis-local:8000
ANALYSIS_BACKFILL_BATCH_SIZE=100
OPENAI_API_KEY=

# Optional: override local database access if your PostgreSQL setup needs it.
# DATABASE_URL=postgres://postgres@localhost:5432/photos_development
