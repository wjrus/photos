RAILS_MASTER_KEY=
SECRET_KEY_BASE=

PHOTOS_HOST=photos.wjr.us
PHOTOS_ASSUME_SSL=true
PHOTOS_FORCE_SSL=true
PHOTOS_DATABASE_PASSWORD=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_ARCHIVE_FOLDER_ID=
GOOGLE_MAPS_EMBED_API_KEY=
PHOTOS_OWNER_EMAIL=wjr@wjr.us
PHOTOS_TRUSTED_VIEWER_EMAILS=

RAILS_LOG_LEVEL=info

# Optional: bind Active Storage originals/variants to a host path instead of the Docker volume.
# On the production VM this should point at the large Unraid mount.
PHOTOS_STORAGE_PATH=

# Optional: host path containing import batches such as Google Takeout zips.
PHOTOS_IMPORT_PATH=/mnt/photos/imports

# Optional: default in-container path for app-queued Google Takeout imports.
PHOTOS_TAKEOUT_IMPORT_PATH=/rails/imports/google-takeout

# Optional: owner-only password for the unlinked private route.
PHOTOS_LOCKED_FOLDER_PASSWORD=
