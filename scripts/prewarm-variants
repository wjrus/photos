#!/usr/bin/env bash
set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

LIMIT="${1:-500}"
SERVICE="${2:-web}"

if [[ "$LIMIT" == "-h" || "$LIMIT" == "--help" ]]; then
  cat <<'USAGE'
Usage:
  ./scripts/prewarm-variants [limit] [service]

Examples:
  ./scripts/prewarm-variants
  ./scripts/prewarm-variants 2000

Queues background work for missing image and video derivatives. It does not
process media inside the web request.
USAGE
  exit 0
fi

docker compose exec -T -e PREWARM_LIMIT="$LIMIT" "$SERVICE" bin/rails runner "$(cat <<'RUBY'
limit = Integer(ENV.fetch("PREWARM_LIMIT", 500))
batch_size = [ limit, 100 ].min
queued = 0
cursor = nil

scope = Photo
  .with_original_variant_records

loop do
  photos = scope.before_stream_cursor(cursor).stream_order.limit(batch_size).to_a
  break if photos.empty?

  photos.each do |photo|
    cursor = photo.stream_cursor
    next unless photo.original.attached?
    if photo.image?
      next if photo.processed_original_variant_record(:stream) && photo.processed_original_variant_record(:display)
    elsif photo.video?
      next if photo.video_derivatives_ready?
    else
      next
    end

    GeneratePhotoDerivativesJob.perform_later(photo)
    queued += 1
    break if queued >= limit
  end

  break if queued >= limit
end

puts "Queued #{queued} derivative #{'job'.pluralize(queued)}."
RUBY
)"
