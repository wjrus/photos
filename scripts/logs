#!/usr/bin/env bash
set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

source "$ROOT/scripts/lib/compose_env"
load_compose_env

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  cat <<'USAGE'
Usage:
  ./scripts/logs [service ...]

Examples:
  ./scripts/logs
  ./scripts/logs web
  ./scripts/logs web worker

When no service is given, this follows app proxy, web backend, and worker logs.
The shorthand service name "web" expands to app_proxy, web_blue, and web_green.
USAGE
  exit 0
fi

if (( $# == 0 )); then
  set -- app_proxy web_blue web_green worker
fi

services=()
for service in "$@"; do
  if [[ "$service" == "web" ]]; then
    services+=(app_proxy web_blue web_green)
  else
    services+=("$service")
  fi
done

COMPOSE_PROFILES="${COMPOSE_PROFILES:-bluegreen}" docker compose logs -f --tail=200 "${services[@]}"
