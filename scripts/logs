#!/usr/bin/env bash
set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

source "$ROOT/scripts/lib/compose_env"
load_compose_env

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  cat <<'USAGE'
Usage:
  ./scripts/logs [service ...]

Examples:
  ./scripts/logs
  ./scripts/logs web
  ./scripts/logs web worker
  ./scripts/logs analysis
  ./scripts/logs all

When no service is given, this follows app proxy and web backend logs.
The shorthand service name "web" expands to app_proxy, web_blue, and web_green.
The shorthand service name "analysis" expands to analysis-local.
The shorthand service name "all" expands to app_proxy, web_blue, web_green, worker, and analysis-local.
USAGE
  exit 0
fi

if (( $# == 0 )); then
  set -- web
fi

services=()
for service in "$@"; do
  case "$service" in
    web) services+=(app_proxy web_blue web_green) ;;
    analysis) services+=(analysis-local) ;;
    all) services+=(app_proxy web_blue web_green worker analysis-local) ;;
    *) services+=("$service") ;;
  esac
done

docker compose logs -f --tail=200 "${services[@]}"
