#!/usr/bin/env bash
set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

SERVICE="${1:-web}"

if [[ "$SERVICE" == "-h" || "$SERVICE" == "--help" ]]; then
  cat <<'USAGE'
Usage:
  ./scripts/prune-stale-jobs [service]

Deletes ready/scheduled stale background jobs that are safe to discard:
ActiveStorage video analysis left over from before video analysis was disabled,
and redundant checksum jobs for photos that already have complete checksums.
USAGE
  exit 0
fi

docker compose exec -T "$SERVICE" bin/rails runner - <<'RUBY'
connection = SolidQueue::Job.connection

analyze_deleted = connection.exec_delete(<<~SQL.squish)
  DELETE FROM solid_queue_jobs
  WHERE class_name = 'ActiveStorage::AnalyzeJob'
SQL

checksum_deleted = 0
SolidQueue::Job.where(class_name: "ChecksumOriginalJob").find_each do |job|
  photo_id = job.arguments.to_s[/gid:\/\/photos\/Photo\/(\d+)/, 1]
  next unless photo_id

  photo = Photo.find_by(id: photo_id)
  next unless photo&.checksum_complete? && photo.checksum_sha256.present?

  job.destroy!
  checksum_deleted += 1
end

puts "Deleted #{analyze_deleted} stale ActiveStorage analyze #{'job'.pluralize(analyze_deleted)}."
puts "Deleted #{checksum_deleted} redundant checksum #{'job'.pluralize(checksum_deleted)}."
RUBY
